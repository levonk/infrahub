graph TD
    subgraph "Client Layer"
        Client[Client Device]
    end

    subgraph "Layer 0: Traffic Interception (Host)"
        direction LR
        nftables[nftables TPROXY<br>Host Port 53 → AdGuard]
    end

    subgraph "Layer 1: AdGuard Policy & Content Filtering"
        direction LR
        keepalived_adguard[Virtual IP Resilience] --> adguard["AdGuard<br>Policy / Content Filtering"]
    end

    subgraph "Layer 2: Load Balancing & Filtering"
        direction LR
        keepalived_dnsdist[Virtual IP Resilience] --> dnsdist["dnsdist<br>172.20.255.49:15353<br>(Entrypoint)"]
        dnsdist --> Blocklist[CDB Blocklist]
        dnsdist --> RateLimit[Rate Limiter]
        dnsdist --> ECSStrip[ECS Stripper]
    end

    subgraph "Layer 3: Caching & Forwarding Orchestration"
        direction LR
        keepalived_coredns[Virtual IP Resilience] --> coredns["CoreDNS<br>172.20.255.51:15353<br>Orchestrator"]
        coredns --> Cache[Cache]
        coredns --> DNSSEC[DNSSEC Validator]
    end

    subgraph "Layer 4: DNS Forwarding Services (Protocol Fallback Chain)"
        direction LR
        subgraph "Tier 1: Oblivious DoH"
            dnscrypt_odoh["dnscrypt-proxy ODoH<br>172.20.255.52:5053"]
        end
        subgraph "Tier 2: Anonymized DNSCrypt"
            keepalived_dnscrypt_anon[Virtual IP Resilience] --> dnscrypt_anon["dnscrypt-proxy Anon<br>172.20.255.53:5053"]
        end
        subgraph "Tier 3: Unbound over Tor to Root"
            keepalived_unbound[Virtual IP Resilience] --> unbound_tor["Unbound over Tor<br>Recursive → Root NS"]
        end
    end

    subgraph "Layer 4b: DNS Forwarding Services (Crazy Resilient Fallback Chain)"
        direction LR
        subgraph "Tier 4: DNS-over-Tor"
            direction TB
            dnscrypt_dnscrypt_tor["dnscrypt-proxy Tor<br>172.20.255.58:5053"]
        end
        subgraph "Tier 5: DoH over Tor"
            dnscrypt_doh_tor["dnscrypt-proxy DoH<br>172.20.255.55:5053"]
        end
        subgraph "Tier 6: TLS over Tor"
            dnscrypt_tls_tor["dnscrypt-proxy DoH<br>172.20.255.55:5053"]
        end
        subgraph "Tier 7: Standard DNSCrypt"
            dnscrypt_std["dnscrypt-proxy STD<br>172.20.255.54:5053"]
        end
        subgraph "Tier 8: DoH"
            dnscrypt_doh["dnscrypt-proxy DoH<br>172.20.255.55:5053"]
        end
        subgraph "Tier 9: Encrypted (TLS)"
            dnscrypt_encrypted["dnscrypt-proxy Encrypted<br>172.20.255.56:5053"]
        end
        subgraph "Tier 10: Unbound to Root"
            unbound_root["Unbound<br>Recursive → Root NS"]
        end
        subgraph "Tier 11: Plaintext over Tor"
            dnscrypt_plaintext_tor["dnscrypt-proxy Plaintext<br>172.20.255.57:5053"]
        end
        subgraph "Tier 12: Plaintext"
            dnscrypt_plaintext["dnscrypt-proxy Plaintext<br>172.20.255.59:5053"]
        end
    end


    subgraph "Layer 5: External Resolvers"
        direction LR
        unbound_tor -- "Forwards through" --> tor_proxy
        dnscrypt_dnscrypt_tor -- "Forwards through" --> tor_proxy
        dnscrypt_doh_tor -- "Forwards through" --> tor_proxy
        dnscrypt_tls_tor -- "Forwards through" --> tor_proxy
        dnscrypt_plaintext_tor -- "Forwards through" --> tor_proxy
        tor_proxy["Tor SOCKS Proxy<br>172.20.255.60:9050"]
        Resolvers(Cloudflare, Google, Quad9, Root NS, etc.)
    end

    %% Connections
    Client -- "DNS Query<br>(port 53)" --> nftables
    nftables -- "Redirect to AdGuard" --> keepalived_adguard
    adguard -- "Filtered DNS" --> keepalived_dnsdist
    dnsdist -- "Forward" --> keepalived_coredns

    coredns -- "Fallback 1" --> dnscrypt_odoh
    coredns -- "Fallback 2" --> keepalived_dnscrypt_anon
    coredns -- "Fallback 3" --> keepalived_unbound_tor
    coredns -- "Fallback 4" --> dnscrypt_dnscrypt_tor
    coredns -- "Fallback 5" --> dnscrypt_std
    coredns -- "Fallback 6" --> dnscrypt_doh
    coredns -- "Fallback 7" --> dnscrypt_encrypted
    coredns -- "Fallback 8" --> unbound_root

    dnscrypt_odoh -- "Encrypted Query" --> Resolvers
    dnscrypt_anon -- "Encrypted Query" --> Resolvers
    tor_proxy -- "via Tor" --> Resolvers
    dnscrypt_std -- "Encrypted Query" --> Resolvers
    dnscrypt_doh -- "Encrypted Query" --> Resolvers
    dnscrypt_encrypted -- "Encrypted Query" --> Resolvers
    unbound_root -- "Recursive Query" --> Resolvers

    Resolvers -- "Response" --> dnscrypt_odoh
    Resolvers -- "Response" --> dnscrypt_anon
    Resolvers -- "Response" --> unbound_tor
    Resolvers -- "Response" --> dnscrypt_dnscrypt_tor
    Resolvers -- "Response" --> dnscrypt_std
    Resolvers -- "Response" --> dnscrypt_doh
    Resolvers -- "Response" --> dnscrypt_encrypted
    Resolvers -- "Response" --> unbound_root

    dnscrypt_odoh -- "Response" --> coredns
    dnscrypt_anon -- "Response" --> coredns
    unbound_tor -- "Response" --> coredns
    dnscrypt_dnscrypt_tor -- "Response" --> coredns
    dnscrypt_std -- "Response" --> coredns
    dnscrypt_doh -- "Response" --> coredns
    dnscrypt_encrypted -- "Response" --> coredns
    unbound_root -- "Response" --> coredns

    coredns -- "Final Response" --> dnsdist
    dnsdist -- "Final Response" --> adguard
	adguard -- "Final Response" --> Client

    %% Styling
    style nftables fill:#D5A6BD
    style dnsdist fill:#A6C1D5
    style coredns fill:#A6D5B2
    style dnscrypt_odoh fill:#D5C4A6
    style dnscrypt_anon fill:#D5B3A6
    style dnscrypt_std fill:#D5A6A6
    style dnscrypt_doh fill:#C4A6D5
    style dnscrypt_encrypted fill:#A6A6D5
    style unbound_root fill:#A6D5D5
    style tor_proxy fill:#E6B8AF
    style adguard fill:#F4CCCC
    style unbound_tor fill:#C9DAF8
