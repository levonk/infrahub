{
  "proxy": {
    "listen": {
      "host": "0.0.0.0",
      "port": 8085
    },
    "target": {
      "host": "claude-code-mcp",
      "port": 8082,
      "protocol": "http"
    },
    "security": {
      "require_auth": true,
      "cors": {
        "enabled": true,
        "allowed_origins": ["http://localhost:3000"],
        "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
        "allowed_headers": ["Content-Type", "Authorization"]
      }
    },
    "timeout": 30000,
    "retry": {
      "max_attempts": 3,
      "backoff_ms": 1000
    }
  },
  "logging": {
    "level": "info",
    "format": "json"
  }
}
