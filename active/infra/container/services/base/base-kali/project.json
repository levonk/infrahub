{
  "name": "localnet-base-kali",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/base/base-kali",
  "tags": ["base", "kali", "security", "docker"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/base/base-kali",
        "file": "services/base/base-kali/Dockerfile.base-kali",
        "tags": ["localnet-base-kali:latest"],
        "push": false,
        "load": true
      }
    }
  }
}
