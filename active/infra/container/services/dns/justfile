# Legacy: help target (just --list is the just way)
help:
    @echo "DNS Service Stack - Build System"
    @echo ""
    @echo "This justfile manages the DNS stack (dnsdist, CoreDNS, dnscrypt-proxy, blocklist compiler)."
    @echo ""
    @echo "Available commands:"
    @just --list

# Legacy: clean-all alias for deep clean
clean-all:
    just clean-all-internal
