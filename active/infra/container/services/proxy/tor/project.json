{
  "name": "localnet-proxy-tor",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/dns/tor",
  "tags": ["service", "dns", "docker"],
  "implicitDependencies": ["localnet-base-alpine"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/dns/tor",
        "file": "services/dns/tor/Dockerfile.tor",
        "tags": ["localnet-proxy-tor:latest"],
        "push": false,
        "load": true
      }
    }
  }
}
