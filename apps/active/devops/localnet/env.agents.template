# Agent Environment Configuration Template
# This file contains environment variables for AI agents

# ============================================================================
# USER AND PERMISSIONS
# ============================================================================

# User and group IDs for container processes
PUID=1000
PGID=1000
USERNAME=cuser

# Timezone
TZ=UTC

# ============================================================================
# OPENFANG CONFIGURATION
# ============================================================================

# OpenFang service configuration
OPENFANG_HOST_PORT=4200
OPENFANG_CONTAINER_PORT=4200
OPENFANG_DATA_DIR=/data/openfang
OPENFANG_CONFIG_DIR=/config/openfang
OPENFANG_ENABLE_AUTH=false
OPENFANG_API_KEY=
OPENFANG_MAX_AGENTS=10
OPENFANG_AGENT_TIMEOUT=300
OPENFANG_HEALTH_TIMEOUT=10

# ============================================================================
# LLM PROVIDER CONFIGURATIONS
# ============================================================================

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini Configuration
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Additional LLM Providers
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
FIREWORKS_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
AI21_API_KEY=
CEREBRAS_API_KEY=
SAMBAANOVA_API_KEY=
HUGGINGFACE_API_KEY=
REPLICATE_API_KEY=

# Local LLM Providers
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=
LM_STUDIO_BASE_URL=

# Chinese LLM Providers
QWEN_API_KEY=
MINIMAX_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
QIANFAN_API_KEY=

# AWS Bedrock Configuration
BEDROCK_ACCESS_KEY=
BEDROCK_SECRET_KEY=
BEDROCK_REGION=us-east-1

# ============================================================================
# AGENT NETWORK CONFIGURATION
# ============================================================================

# Agent network configuration
AGENT_NETWORK_SUBNET=172.20.0.0/16
AGENT_NETWORK_GATEWAY=172.20.0.1

# DMZ network configuration (for controlled access)
DMZ_NETWORK_SUBNET=172.21.0.0/16
DMZ_NETWORK_GATEWAY=172.21.0.1

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Security agent configuration
SECURITY_AGENT_ISOLATION=true
SECURITY_AGENT_DMZ_ACCESS=false
SECURITY_AGENT_LOG_LEVEL=info

# Agent trust levels
AGENT_TRUST_LEVELS=high,medium,low
DEFAULT_AGENT_TRUST_LEVEL=medium

# ============================================================================
# MONITORING AND LOGGING
# ============================================================================

# Agent monitoring configuration
AGENT_MONITORING_ENABLED=true
AGENT_LOG_RETENTION_DAYS=30
AGENT_METRICS_PORT=9090

# Security event logging
SECURITY_EVENT_LOGGING=true
SECURITY_EVENT_RETENTION_DAYS=90

# ============================================================================
# RESOURCE LIMITS
# ============================================================================

# Default resource limits for agents
AGENT_DEFAULT_CPU_LIMIT=2.0
AGENT_DEFAULT_MEMORY_LIMIT=2G
AGENT_DEFAULT_CPU_RESERVATION=0.5
AGENT_DEFAULT_MEMORY_RESERVATION=512M

# Security agent resource limits
SECURITY_AGENT_CPU_LIMIT=4.0
SECURITY_AGENT_MEMORY_LIMIT=4G
SECURITY_AGENT_CPU_RESERVATION=1.0
SECURITY_AGENT_MEMORY_RESERVATION=1G

# ============================================================================
# PERSISTENT STORAGE
# ============================================================================

# Agent data storage paths
AGENT_DATA_BASE_DIR=/data/agents
AGENT_CONFIG_BASE_DIR=/config/agents
AGENT_LOGS_BASE_DIR=/logs/agents

# OpenFang storage paths
OPENFANG_STORAGE_PATH=/data/openfang/storage
OPENFANG_LOGS_PATH=/data/openfang/logs
OPENFANG_BACKUP_PATH=/data/openfang/backup

# ============================================================================
# DEVELOPMENT AND DEBUGGING
# ============================================================================

# Development configuration
AGENT_DEV_MODE=false
AGENT_DEBUG_LOGGING=false
AGENT_VERBOSE_OUTPUT=false

# Testing configuration
AGENT_TEST_MODE=false
AGENT_MOCK_LLM_RESPONSES=false

# ============================================================================
# INTEGRATION CONFIGURATION
# ============================================================================

# LocalNet integration
LOCALNET_INTEGRATION=false
LOCALNET_DMZ_ACCESS=false
LOCALNET_SHARED_VOLUMES=false

# External service integration
EXTERNAL_API_TIMEOUT=30
EXTERNAL_API_RETRIES=3
EXTERNAL_API_RETRY_DELAY=5

# ============================================================================
# COMPLIANCE AND AUDIT
# ============================================================================

# Compliance configuration
AGENT_AUDIT_LOGGING=true
AGENT_SESSION_RECORDING=false
AGENT_DATA_ENCRYPTION=true

# GDPR and privacy configuration
AGENT_DATA_RETENTION_DAYS=365
AGENT_ANONYMIZATION_ENABLED=true
AGENT_CONSENT_MANAGEMENT=true
