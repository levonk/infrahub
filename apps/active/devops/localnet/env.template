# Home Lab In-a-Box Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# Network Configuration
# ============================================================================

# Your server's IP address (REQUIRED - change this!)
HOST_IP=192.168.2.214

# Docker network subnet (tuned to avoid common overlaps; adjust only if still conflicting)
LOCALNET_PEER_NETWORK_SUBNET=172.20.0.0/16

# Transparent proxy packet marking
TRANSPARENT_PROXY_MARK=1

# ============================================================================
# Transparent Gateway Configuration
# ============================================================================

# Metrics endpoint port mapping
TRANSPARENT_GATEWAY_METRICS_CONTAINER_PORT=9099
TRANSPARENT_GATEWAY_METRICS_HOST_PORT=9099

# ============================================================================
# DNS Configuration
# ============================================================================

# ⚠️  IMPORTANT: DNS Service IPs are RESERVED in docker-compose.yml aux_addresses
# These IPs are locked to prevent DHCP assignment. Changing them requires updating:
#   1. .env (this file)
#   2. docker-compose.localnet.yml (aux_addresses section)
#   3. services/dns/docker-compose.dns.yml (service ipv4_address)
# See: internal-docs/adr/adr-dns-high-ip-range.md for architecture details

# Port configuration
# DNS_TRANSPARENT_HOST_PORT: Host port for transparent mode (default 5353)
# Note: On WSL2, port 53 cannot be bound from containers (Windows reserves it)
# Using port 5353 on host mapped to 5353 in container instead
DNS_TRANSPARENT_HOST_PORT=5353
DNS_TRANSPARENT_CONTAINER_PORT=5353

# DNS_DNSDIST_MAIN_HOST_PORT: Host port for direct mode (default 15353)
DNS_DNSDIST_MAIN_HOST_PORT=15353
DNS_DNSDIST_MAIN_CONTAINER_PORT=5353
DNS_DNSDIST_CONTROL_CONTAINER_PORT=5199
DNS_DNSDIST_WEB_CONTAINER_PORT=8053
#openssl rand -base64 16
DNS_DNSDIST_WEB_API_KEY=superSecretDnsdistApiKey
DNS_DNSDIST_WEB_PASSWORD=superSecretWebPassword456@
DNS_DNSDIST_CONTROL_PASSWORD=superSecretControlPassword123!

# CoreDNS port configuration
# DNS_COREDNS_MAIN_HOST_PORT: Host port for CoreDNS (default 15354)
DNS_COREDNS_MAIN_IP=172.21.255.51
DNS_COREDNS_MAIN_HOST_PORT=15354
DNS_COREDNS_MAIN_CONTAINER_PORT=15353
DNS_COREDNS_MAIN_METRICS_HOST_PORT=9153
DNS_COREDNS_MAIN_HEALTH_HOST_PORT=27493
DNS_COREDNS_MAIN_HEALTH_CONTAINER_PORT=18080

# DNSDist metrics
DNS_DNSDIST_METRICS_HOST_PORT=8083
DNS_DNSDIST_METRICS_CONTAINER_PORT=8083

# dnscrypt-proxy
DNS_DNSCRYPT_PROXY_IP=5350
DNS_DNSCRYPT_PROXY_CONTAINER_PORT=5053
DNS_DNSCRYPT_PROXY_HOST_PORT=5350

# dnscrypt-proxy service IPs and ports - ODOH (Oblivious DNS over HTTPS)
DNS_DNSCRYPT_ODOH_IP=172.20.255.60
DNS_DNSCRYPT_ODOH_CONTAINER_PORT=5053
DNS_DNSCRYPT_ODOH_HOST_PORT=5360

# dnscrypt-proxy service IPs and ports - Tor (DNS over Tor)
DNS_DNSCRYPT_TOR_IP=172.20.255.66
DNS_DNSCRYPT_TOR_CONTAINER_PORT=5053
DNS_DNSCRYPT_TOR_HOST_PORT=5366

# dnscrypt-proxy service IPs and ports - Anonymous
DNS_DNSCRYPT_ANON_IP=172.20.255.61
DNS_DNSCRYPT_ANON_CONTAINER_PORT=5054
DNS_DNSCRYPT_ANON_HOST_PORT=5361

# dnscrypt-proxy service IPs and ports - Standard
DNS_DNSCRYPT_STD_IP=172.20.255.62
DNS_DNSCRYPT_STD_CONTAINER_PORT=5055
DNS_DNSCRYPT_STD_HOST_PORT=5362

# dnscrypt-proxy service IPs and ports - DoH (DNS over HTTPS)
DNS_DNSCRYPT_DOH_IP=172.20.255.63
DNS_DNSCRYPT_DOH_CONTAINER_PORT=5056
DNS_DNSCRYPT_DOH_HOST_PORT=5363

# dnscrypt-proxy service IPs and ports - Encrypted
DNS_DNSCRYPT_ENCRYPTED_IP=172.20.255.64
DNS_DNSCRYPT_ENCRYPTED_CONTAINER_PORT=5057
DNS_DNSCRYPT_ENCRYPTED_HOST_PORT=5364

# dnscrypt-proxy service IPs and ports - Plaintext
DNS_DNSCRYPT_PLAINTEXT_IP=172.20.255.65
DNS_DNSCRYPT_PLAINTEXT_CONTAINER_PORT=5058
DNS_DNSCRYPT_PLAINTEXT_HOST_PORT=5365

# Tor proxy service IP and port
PROXY_TOR_SOCKS5_IP=172.21.255.70
PROXY_TOR_SOCKS5_CONTAINER_PORT=9050
PROXY_TOR_SOCKS_HOST_PORT=9050
PROXY_TOR_CONTROL_HOST_PORT=9051

# Upstream DNS servers
DNS_UPSTREAM_PRIMARY=1.1.1.1
DNS_UPSTREAM_SECONDARY=8.8.8.8

# Cache settings
DNS_CACHE_TTL=3600

# Blocklist update frequency (daily, weekly, monthly)
DNS_BLOCKLIST_UPDATE_INTERVAL=daily

# ============================================================================
# NTP Configuration
# ============================================================================

# Transparent Mode (main entry point)
NTP_TRANSPARENT_HOST_PORT=123
NTP_TRANSPARENT_CONTAINER_PORT=123

# Direct Mode (testing/debugging)
NTP_DIRECT_HOST_PORT=1123
NTP_DIRECT_CONTAINER_PORT=1123

# NTS (Network Time Security) Key Exchange
CHRONYD_NTS_HOST_PORT=4460

# Metrics (Prometheus)
CHRONYD_METRICS_HOST_PORT=9123

# Primary NTP server (supports leap smearing)
NTP_PRIMARY_SERVER=time.google.com

# Enable Network Time Security (recommended)
NTP_ENABLE_NTS=true

# Enable Tor for NTP (NOT recommended - adds latency)
NTP_ENABLE_TOR=false

# ============================================================================
# Web Proxy Configuration
# ============================================================================

# Transparent Gateway Metrics (Prometheus)
TRANSPARENT_GATEWAY_METRICS_HOST_PORT=9099
TRANSPARENT_GATEWAY_METRICS_CONTAINER_PORT=9099

# Envoy Proxy - Internal
ENVOY_INTERNAL_HOST_PORT=3129

# Envoy Proxy - Admin + Metrics
ENVOY_ADMIN_HOST_PORT=9901

# Tor SOCKS5 proxy
PROXY_TOR_SOCKS_HOST_PORT=9050

# Tor Control port
PROXY_TOR_CONTROL_HOST_PORT=9051

# Cache size in MB
PROXY_CACHE_SIZE_MB=10240

# Enable Tor for web traffic (recommended for privacy)
PROXY_ENABLE_TOR=true

# ============================================================================
# Artifact Repository Configuration
# ============================================================================

# Nexus - Web UI
ARTIFACT_NEXUS_WEB_CONTAINER_PORT=8081
ARTIFACT_NEXUS_WEB_HOST_PORT=8081

# Nexus - Docker Registry
ARTIFACT_NEXUS_DOCKER_HOST_PORT=8082

# Verdaccio - NPM Registry
ARTIFACT_VERDACCIO_CONTAINER_PORT=4873
ARTIFACT_VERDACCIO_HOST_PORT=4873

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Log format (json, text)
LOG_FORMAT=json

# Vector - Metrics endpoint (Prometheus)
VECTOR_METRICS_HOST_PORT=9598

# Elasticsearch - API
ELASTICSEARCH_HTTP_HOST_PORT=9200

# Elasticsearch - Cluster communication
ELASTICSEARCH_TRANSPORT_HOST_PORT=9300

# Loki - Log aggregation
LOKI_HOST_PORT=3100

# Promtail - Metrics endpoint (Prometheus)
PROMTAIL_METRICS_HOST_PORT=9080

# Retention periods (days)
ELASTICSEARCH_RETENTION_DAYS=30
LOKI_RETENTION_DAYS=30

# SECURITY: Elasticsearch authentication (CHANGE THIS!)
ELASTICSEARCH_PASSWORD=changeme_PLEASE_SET_STRONG_PASSWORD

# Vector buffer size in MB
VECTOR_BUFFER_SIZE_MB=256

# ============================================================================
# Monitoring Configuration
# ============================================================================

# Prometheus - Time series database
PROMETHEUS_HOST_PORT=19090

# Grafana - Dashboards and visualization
GRAFANA_HOST_PORT=3000

# Jaeger - Distributed tracing UI
JAEGER_UI_HOST_PORT=16686

# Jaeger - Zipkin compatible endpoint
JAEGER_ZIPKIN_HOST_PORT=9411

# Jaeger - Collector endpoint
JAEGER_COLLECTOR_HOST_PORT=14268

# Blackbox Exporter - Endpoint monitoring
BLACKBOX_EXPORTER_HOST_PORT=9115

# Retention period (days)
PROMETHEUS_RETENTION_DAYS=30

# Grafana admin password (CHANGE THIS!)
GRAFANA_ADMIN_PASSWORD=changeme

# Jaeger sampling rate (0.0-1.0)
JAEGER_SAMPLING_RATE=0.1

# ============================================================================
# WireGuard VPN Configuration
# ============================================================================

# WireGuard server URL (auto-detect or set manually)
WIREGUARD_SERVERURL=auto

# Timezone for WireGuard containers
TZ=UTC

# ============================================================================
# LocalStack AWS Development Environment
# ============================================================================

# LocalStack edge port (all AWS services)
LOCALSTACK_CONTAINER_PORT=4566

# LocalStack external services port range
LOCALSTACK_CONTAINER_PORT_EXT=4510-4559

# AWS services to enable (comma-separated)
# Available: s3,dynamodb,lambda,sqs,sns,cloudwatch,logs,events,secretsmanager,ssm,etc.
LOCALSTACK_SERVICES=s3,dynamodb,lambda,sqs,sns,cloudwatch,logs,events,secretsmanager,ssm

# Enable debug mode (0=off, 1=on)
LOCALSTACK_DEBUG=0

# Enable data persistence across restarts (0=off, 1=on)
LOCALSTACK_PERSISTENCE=1

# WireGuard Docker network subnet
WIREGUARD_NETWORK_SUBNET=172.21.0.0/16

# --- WireGuard Direct Mode (wg0) - Port 51820 ---
# VPN clients have direct internet access, optional localnet services

# Direct mode listen port
WIREGUARD_DIRECT_CONTAINER_PORT=51820

# Number of direct mode client peers to generate
WIREGUARD_DIRECT_PEERS=5

# Networks accessible through direct VPN (split-tunnel)
# Format: network1,network2,host/32
WIREGUARD_DIRECT_ALLOWEDIPS=172.20.0.0/16,192.168.2.214/32

# --- WireGuard Transparent Mode (wg1) - Port 51821 ---
# VPN clients under observation, MUST use localnet services

# Transparent mode listen port
WIREGUARD_TRANSPARENT_CONTAINER_PORT=51821

# Number of transparent mode client peers to generate (for managed devices)
WIREGUARD_TRANSPARENT_PEERS=3

# ============================================================================
# Privacy Configuration
# ============================================================================

# Enable Oblivious DNS over HTTPS (recommended)
ENABLE_ODOH=true

# Enable Tor for DNS (adds latency, optional)
ENABLE_TOR_DNS=false

# Enable Tor for web traffic (recommended)
ENABLE_TOR_WEB=true

# Strip EDNS Client Subnet information (recommended)
STRIP_ECS=true

# ============================================================================
# Remote Logging (Optional - BetterStack Free Tier)
# ============================================================================

BETTERSTACK_ENABLED=false
BETTERSTACK_TOKEN=

# ============================================================================
# Claude Code Integration Configuration
# ============================================================================

# Claude API Configuration
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Claude Code JWT Secret (generate a secure random string)
CLAUDE_CODE_JWT_SECRET=your_secure_jwt_secret_here

# Claude Code Intercept port configuration
CLAUDE_CODE_INTERCEPT_API_CONTAINER_PORT=3001
CLAUDE_CODE_INTERCEPT_API_HOST_PORT=3001
CLAUDE_CODE_INTERCEPT_UI_CONTAINER_PORT=5173
CLAUDE_CODE_INTERCEPT_UI_HOST_PORT=5173

# Claude Code Database Password
CLAUDE_CODE_DB_PASSWORD=your_secure_db_password_here

