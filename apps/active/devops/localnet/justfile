    devbox run test-claude-internal

test-claude-internal:
    @./scripts/echo-colors.sh blue "Running Claude Code service tests..."
    @{{DC_LOCAL}} --profile claude-code ps | grep -q "claude-code" && @./scripts/echo-colors.sh green "✓ Claude Code services are running" || (@./scripts/echo-colors.sh red "✗ Claude Code services not running"; exit 1)
    @./scripts/echo-colors.sh blue "Testing Claude Code API health..."
    @{{DC_LOCAL}} exec -T claude-code curl -f http://localhost:8081/health >/dev/null 2>&1 && @./scripts/echo-colors.sh green "✓ Claude Code API healthy" || @./scripts/echo-colors.sh yellow "⚠ Claude Code API not responding"
    @{{DC_LOCAL}} exec -T claude-code-ui curl -f http://localhost:3000/health >/dev/null 2>&1 && @./scripts/echo-colors.sh green "✓ Claude Code UI healthy" || @./scripts/echo-colors.sh yellow "⚠ Claude Code UI not responding"
    @{{DC_LOCAL}} exec -T claude-code-auth curl -f http://localhost:8080/health >/dev/null 2>&1 && @./scripts/echo-colors.sh green "✓ Claude Code Auth healthy" || @./scripts/echo-colors.sh yellow "⚠ Claude Code Auth not responding"
    @./scripts/echo-colors.sh green "✓ Claude Code tests complete"

