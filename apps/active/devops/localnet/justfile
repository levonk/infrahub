# View just execution log
view-log:
    @if [ -f {{LOG_FILE}} ]; then \
        ./scripts/echo-colors.sh blue "=== Just Execution Log ==="; \
        cat {{LOG_FILE}}; \
    else \
        ./scripts/echo-colors.sh yellow "No log file found at {{LOG_FILE}}"; \
    fi

# Tail just execution log (follow mode)
tail-log:
    @if [ -f {{LOG_FILE}} ]; then \
        ./scripts/echo-colors.sh blue "=== Tailing Just Log (Ctrl+C to exit) ==="; \
        tail -f {{LOG_FILE}}; \
    else \
        ./scripts/echo-colors.sh yellow "No log file found at {{LOG_FILE}}"; \
    fi

# Clear just execution log
clear-log:
    @./scripts/echo-colors.sh yellow "Clearing log file..."
    @rm -f {{LOG_FILE}}
    @./scripts/echo-colors.sh green "✓ Log cleared"

# ============================================================================
# NX Build Orchestration (NEW - Phase 8.6)
# ============================================================================

# NX: Build base images (foundation layer)
nx-build-base:
    devbox run nx-build-base-internal

nx-build-base-internal:
    @./scripts/echo-colors.sh blue "NX: Building base images with dependency graph..."
    @if [ "{{NX_AVAILABLE}}" = "true" ]; then \
        {{NX_BIN}} run-many --verbose -t docker:build --projects=tag:base --parallel=1; \
    else \
        echo "NX not installed, falling back to legacy build..."; \
        just base-up; \
    fi

# NX: Build sidecars (depends on base images)
nx-build-sidecars:
    devbox run nx-build-sidecars-internal

nx-build-sidecars-internal:
    @./scripts/echo-colors.sh blue "NX: Building sidecar containers..."
    @if [ "{{NX_AVAILABLE}}" = "true" ]; then \
        {{NX_BIN}} run-many --verbose -t docker:build --projects=tag:sidecar --parallel=2; \
    else \
        echo "NX not installed, using docker compose..."; \
        just up-core-nix-internal; \
    fi

# NX: Build all services (uses dependency graph for optimal ordering)
nx-build:
    devbox run nx-build-internal

nx-build-internal:
    @./scripts/echo-colors.sh blue "NX: Building all services with smart caching..."
    @if [ "{{NX_AVAILABLE}}" = "true" ]; then \
        {{NX_BIN}} run-many --verbose -t docker:build --all --parallel=2; \
    else \
        echo "NX not installed, falling back to just build..."; \
        just build-internal; \
    fi

# NX: Build only affected services (changed since last commit)
nx-affected:
    devbox run nx-affected-internal

nx-affected-internal:
    @./scripts/echo-colors.sh blue "NX: Building only affected services..."
    @if [ "{{NX_AVAILABLE}}" = "true" ]; then \
        {{NX_BIN}} affected --verbose -t docker:build --base=main --head=HEAD; \
    else \
        echo "NX not installed"; \
        exit 1; \
    fi

# NX: Visualize dependency graph
nx-graph:
    devbox run nx-graph-internal

nx-graph-internal:
    @./scripts/echo-colors.sh blue "NX: Opening dependency graph..."
    @if [ "{{NX_AVAILABLE}}" = "true" ]; then \
        {{NX_BIN}} graph; \
    else \
        echo "NX not installed. Run: pnpm install"; \
        exit 1; \
    fi

# NX: Install dependencies
nx-install:
    devbox run nx-internal-internal

nx-install-internal:
    @./scripts/echo-colors.sh blue "Installing NX dependencies..."
    @export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}" && \
        export PATH="$PNPM_HOME:$PATH" && \
        pnpm install && \
        ./scripts/echo-colors.sh green "✓ NX dependencies installed"

# NX: Clear build cache
nx-clear-cache:
    devbox run nx-clear-cache-internal

nx-clear-cache-internal:
    @./scripts/echo-colors.sh yellow "Clearing NX build cache..."
    @rm -rf .nx/cache
    @docker builder prune -f
    @./scripts/echo-colors.sh green "✓ NX cache cleared"

# ============================================================================
# NX + Docker Compose Hybrid Commands
# ============================================================================

# Build with NX, deploy with Docker Compose (recommended workflow)
nx-up-base:
    devbox run nx-up-base-internal

nx-up-base-internal:
    @just nx-build-base-internal
    @./scripts/echo-colors.sh blue "Starting base infrastructure..."
    @{{DC_LOCAL}} --profile base01 --profile base02 --profile base03 up -d

nx-up-artifacts:
    devbox run nx-up-artifacts-internal

nx-up-artifacts-internal:
    @just nx-build-sidecars-internal
    @./scripts/echo-colors.sh blue "Starting artifact services..."
    @{{DC_LOCAL}} --profile artifact up -d

# ============================================================================
# Aliases for common commands
# ============================================================================
alias rebuild := clean
alias health := health-check
alias status := ps
alias stop := down
alias start := up
