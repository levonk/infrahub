    devbox run down-internal

down-internal:
    @just log-start "down"
    just cloud-down
    @./scripts/echo-colors.sh yellow "Stopping all services..."
    @({{DC_CLOUD}} down 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (./scripts/echo-colors.sh green "✓ Services stopped"; just log-end "down" "SUCCESS") || (./scripts/echo-colors.sh red "✗ Services failed to stop"; just log-end "down" "FAILED"; exit 1)

# Restart all services
