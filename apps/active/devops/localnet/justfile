    @({{DC_LOCAL}} --profile all --progress=plain restart 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (./scripts/echo-colors.sh green "✓ Services restarted"; just log-end "restart" "SUCCESS") || (./scripts/echo-colors.sh red "✗ Services failed to restart"; just log-end "restart" "FAILED"; exit 1)

# Remove all containers, volumes, and networks, then restart services
clean:
    devbox run clean-internal

clean-internal:
    @just log-start "clean"
    @./scripts/echo-colors.sh yellow "Cleaning up Docker resources and restarting..."
    @./scripts/echo-colors.sh blue "Stopping and removing all containers..."
    @({{DC_LOCAL}} --profile all down -v --remove-orphans 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) || true
    @./scripts/echo-colors.sh blue "Force-removing any stuck containers..."
    ./scripts/cleanup-containers.sh 2>&1 | tee -a {{LOG_FILE}} || true
    @./scripts/echo-colors.sh blue "Removing networks..."
    @docker network rm {{NETWORK_NAME}} 2>&1 | tee -a {{LOG_FILE}} || true
    @docker network rm localnet_default 2>&1 | tee -a {{LOG_FILE}} || true
    @./scripts/echo-colors.sh blue "NOT Pruning volumes..."
    @./scripts/echo-colors.sh blue "Pruning builder..."
    @docker builder prune -af 2>&1 | tee -a {{LOG_FILE}} || true
    @./scripts/echo-colors.sh blue "Pruning system..."
    @docker system prune -af 2>&1 | tee -a {{LOG_FILE}} || true
    @sleep 2
    @./scripts/echo-colors.sh green "✓ Cleanup complete, starting services..."
    just up 2>&1 | tee -a {{LOG_FILE}}
    @just log-end "clean" "SUCCESS"

