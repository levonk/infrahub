    @./scripts/echo-colors.sh green "✓ LocalNet started"

# Environment-specific deployments
up-prod:
    devbox run up-prod

up-prod-internal:
    @./scripts/echo-colors.sh blue "Starting production environment..."
    COMPOSE_ENV=production docker compose -f docker-compose.localnet.yml --profile base01 up -d
    @./scripts/echo-colors.sh green "✓ Production environment started"

up-test:
    devbox run up-test

up-test-internal:
    @./scripts/echo-colors.sh blue "Starting testing environment..."
    COMPOSE_ENV=testing docker compose -f docker-compose.localnet.yml --profile agents up -d
    @./scripts/echo-colors.sh green "✓ Testing environment started"

# Memory management & task tracking (NEW - ADR-20260322003)
doc-search query=".":
    @./scripts/echo-colors.sh blue "Searching documentation and memory..."
    @if command -v qmd >/dev/null 2>&1; then \
        qmd search "{{query}}" | head -20; \
    else \
        echo "qmd not found - install with: cargo install qmd"; \
        echo "Falling back to ripgrep..."; \
        rg --type md "{{query}}" docs/ internal-docs/ memory/ || true; \
    fi

doc-search-internal query=".":
    @./scripts/echo-colors.sh blue "Searching documentation and memory..."
    @if command -v qmd >/dev/null 2>&1; then \
        qmd search "{{query}}" | head -20; \
    else \
        echo "qmd not found - install with: cargo install qmd"; \
        echo "Falling back to ripgrep..."; \
        rg --type md "{{query}}" docs/ internal-docs/ memory/ || true; \
    fi

tasks:
    devbox shell tasks

tasks-internal:
    @./scripts/echo-colors.sh blue "Listing open tasks..."
    @if [ -f ".devbox/nix/profile/default/bin/tkr" ]; then \
        .devbox/nix/profile/default/bin/tkr list --status=open; \
    elif command -v tkr >/dev/null 2>&1; then \
        tkr list --status=open; \
    else \
        echo "tkr not found - install from: https://github.com/levonk/tkr"; \
    fi

task-ready:
    devbox shell task-ready

task-ready-internal:
    @./scripts/echo-colors.sh blue "Getting next available task..."
    @if [ -f ".devbox/nix/profile/default/bin/tkr" ]; then \
        .devbox/nix/profile/default/bin/tkr ready; \
    elif command -v tkr >/dev/null 2>&1; then \
        tkr ready; \
    else \
        echo "tkr not found - install from: https://github.com/levonk/tkr"; \
    fi

task-start:
    devbox shell task-start

task-start-internal:
    @./scripts/echo-colors.sh blue "Starting available task..."
    @if command -v tkr >/dev/null 2>&1; then \
        task_id=$$(tkr ready | head -1 | cut -d' ' -f1); \
        if [ -n "$$task_id" ]; then \
            tkr start "$$task_id"; \
            echo "Started task: $$task_id"; \
        else \
            echo "No available tasks"; \
        fi; \
    else \
        echo "tkr not found - install from: https://github.com/levonk/tkr"; \
    fi

# Start all services
up:
    devbox run up

up-internal:
    just build
    @./scripts/echo-colors.sh blue "Starting all services..."
    @sleep 1
    @docker compose -f docker-compose.localnet.yml --profile all --env-file {{ENV_FILE}} --progress=plain up -d
    @./scripts/echo-colors.sh green "✓ Services started"
    @echo "Run 'just health-check' to verify service health"

# Stop all services
down:
    devbox run down

down-internal:
    just cloud-down
    @./scripts/echo-colors.sh yellow "Stopping all services..."
    @docker compose -f docker-compose.cloud.yml --progress=plain down
    @./scripts/echo-colors.sh green "✓ Services stopped"

# Restart all services
restart:
    devbox run restart

restart-internal:
    @./scripts/echo-colors.sh yellow "Restarting all services..."
    @docker compose -f docker-compose.localnet.yml --profile all --progress=plain restart
    @./scripts/echo-colors.sh green "✓ Services restarted"

# Remove all containers, volumes, and networks, then restart services
clean:
    devbox run clean

clean-internal:
    @./scripts/echo-colors.sh yellow "Cleaning up Docker resources and restarting..."
    @./scripts/echo-colors.sh blue "Stopping and removing all containers..."
    docker compose down -f docker-compose.localnet.yml --profile all -v --remove-orphans 2>/dev/null || true
    @./scripts/echo-colors.sh blue "Force-removing any stuck containers..."
    ./scripts/cleanup-containers.sh
    @./scripts/echo-colors.sh blue "Removing networks..."
    docker network rm {{NETWORK_NAME}} 2>/dev/null || true
    docker network rm localnet_default 2>/dev/null || true
    @./scripts/echo-colors.sh blue "Pruning system..."
    docker system prune -f --volumes
    sleep 2
    @./scripts/echo-colors.sh green "✓ Cleanup complete, starting services..."
    just up

# View logs from all services (last 100 lines)
logs:
    devbox run logs

logs-internal:
    docker compose logs -f docker-compose.localnet.yml --profile all --tail=100

# Follow logs from all services
logs-follow:
    docker compose logs -f docker-compose.localnet.yml --profile all -f

# Check health status of all services
health-check:
    devbox run health-check

health-check-internal:
    @./scripts/echo-colors.sh blue "Checking service health..."
    docker compose -f docker-compose.localnet.yml --profile all ps
    @echo ""
    @./scripts/echo-colors.sh blue "Running health checks..."
    ./scripts/health-checks/nftables-check.sh || @./scripts/echo-colors.sh yellow "⚠ nftables check failed"
    @./scripts/echo-colors.sh green "✓ Health check complete"

# Run E2E tests (quick subset)
test:
    devbox run test

test-internal:
    @./scripts/echo-colors.sh blue "Running E2E tests..."
    ./scripts/tests/test-dns-services.sh
    ./scripts/tests/test-monitoring.sh
    @./scripts/echo-colors.sh green "✓ Tests complete"

# Run all E2E tests (comprehensive)
test-all:
    @./scripts/echo-colors.sh blue "Running all E2E tests..."
    ./scripts/tests/run-all-tests.sh

# Update DNS/web blocklists
update-blocklists:
    @./scripts/echo-colors.sh blue "Updating blocklists..."
    @docker compose exec dnsdist /blocklists/update-blocklists.sh
    @./scripts/echo-colors.sh green "✓ Blocklists updated"

# Remove Docker-created config directories (safe, no data loss)
clean-configs:
    devbox run clean-configs

clean-configs-internal:
    @./scripts/echo-colors.sh blue "Cleaning up Docker-created config directories..."
    @docker run --rm -v "{{justfile_directory()}}/configs:/configs" alpine sh -c '\
        find /configs -type d \( \
            -name "*.conf" -o \
            -name "*.yaml" -o \
            -name "*.yml" -o \
            -name "config" -o \
            -name "config.yaml" \
        \) -exec rm -rf {} + 2>/dev/null || true'
    @./scripts/echo-colors.sh green "✓ Config directories removed"
    @echo "Run .just fix-configs. to recreate config files"

# Recreate all config files from templates
fix-configs:
    devbox run fix-configs

fix-configs-internal:
    devbox run clean-configs
    @./scripts/echo-colors.sh blue "Recreating config files..."
    @./scripts/create-configs.sh
    @./scripts/echo-colors.sh green "✓ Config files created"

# Remove all containers, volumes, and networks, then restart services
clean-full:
    devbox run clean-full

clean-full-internal:
    @./scripts/echo-colors.sh yellow "Cleaning up Docker resources and restarting..."
    @./scripts/echo-colors.sh blue "Stopping and removing all containers..."
    docker compose down -f docker-compose.localnet.yml --profile all -v --remove-orphans 2>/dev/null || true
    @./scripts/echo-colors.sh blue "Force-removing any stuck containers..."
    ./scripts/cleanup-containers.sh
    @./scripts/echo-colors.sh blue "Removing networks..."
    docker network rm {{NETWORK_NAME}} 2>/dev/null || true
    docker network rm localnet_default 2>/dev/null || true
    @./scripts/echo-colors.sh blue "Pruning system..."
    docker system prune -f --volumes
    sleep 2
    @./scripts/echo-colors.sh green "✓ Cleanup complete, starting services..."
    just up

# Show running containers
ps:
    devbox run ps

ps-internal:
    @docker compose -f docker-compose.localnet.yml --profile all ps

# Show container resource usage
stats:
    devbox run stats

stats-internal:
    @docker stats --no-stream

# Pull latest container images
pull:
    devbox run pull

pull-internal:
    @./scripts/echo-colors.sh blue "Pulling latest images..."
    @docker compose -f docker-compose.localnet.yml --profile all pull
    @./scripts/echo-colors.sh green "✓ Images updated"

# Validate docker-compose.yml configuration
config:
    devbox run config

config-internal:
    @./scripts/echo-colors.sh blue "Validating configuration..."
    @docker compose config -f docker-compose.localnet.yml --profile all > /dev/null
    @./scripts/echo-colors.sh green "✓ Configuration valid"

# Lint docker-compose.yml and YAML files
lint:
    devbox run lint

lint-internal:
    @./scripts/echo-colors.sh blue "Linting configuration files..."
    @docker compose config -f docker-compose.localnet.yml --profile all > /dev/null && @./scripts/echo-colors.sh green "✓ docker-compose.yml syntax valid" || (@./scripts/echo-colors.sh red "✗ docker-compose.yml syntax invalid"; exit 1)
    if command -v yamllint >/dev/null 2>&1; then \
        find . -name "*.yml" -o -name "*.yaml" | xargs yamllint --no-warnings || @./scripts/echo-colors.sh yellow "⚠ yamllint not configured"; \
    else \
        @./scripts/echo-colors.sh yellow "⚠ yamllint not installed"; \
    fi
    @./scripts/echo-colors.sh green "✓ Lint complete"

# Run tests for Claude Code services
test-claude:
    devbox run test-claude

test-claude-internal:
    @./scripts/echo-colors.sh blue "Running Claude Code service tests..."
    @docker compose --profile claude-code ps | grep -q "claude-code" && @./scripts/echo-colors.sh green "✓ Claude Code services are running" || (@./scripts/echo-colors.sh red "✗ Claude Code services not running"; exit 1)
    @./scripts/echo-colors.sh blue "Testing Claude Code API health..."
    @docker compose exec -f docker-compose.localnet.yml -T claude-code curl -f http://localhost:8081/health >/dev/null 2>&1 && @./scripts/echo-colors.sh green "✓ Claude Code API healthy" || @./scripts/echo-colors.sh yellow "⚠ Claude Code API not responding"
    @docker compose exec -f docker-compose.localnet.yml -T claude-code-ui curl -f http://localhost:3000/health >/dev/null 2>&1 && @./scripts/echo-colors.sh green "✓ Claude Code UI healthy" || @./scripts/echo-colors.sh yellow "⚠ Claude Code UI not responding"
    @docker compose exec -f docker-compose.localnet.yml -T claude-code-auth curl -f http://localhost:8080/health >/dev/null 2>&1 && @./scripts/echo-colors.sh green "✓ Claude Code Auth healthy" || @./scripts/echo-colors.sh yellow "⚠ Claude Code Auth not responding"
    @./scripts/echo-colors.sh green "✓ Claude Code tests complete"

# Lint Claude Code docker-compose configuration
lint-claude:
    devbox run lint-claude

lint-claude-internal:
    @./scripts/echo-colors.sh blue "Linting Claude Code configuration..."
    @docker compose -f services/ai-codeassist/claude-code/claude-code/docker-compose.claude-code.yml config > /dev/null && @./scripts/echo-colors.sh green "✓ Claude Code docker-compose.yml syntax valid" || (@./scripts/echo-colors.sh red "✗ Claude Code docker-compose.yml syntax invalid"; exit 1)
    if command -v yamllint >/dev/null 2>&1; then \
        yamllint services/ai-codeassist/claude-code/claude-code/docker-compose.claude-code.yml || @./scripts/echo-colors.sh yellow "⚠ yamllint issues found"; \
    else \
        @./scripts/echo-colors.sh yellow "⚠ yamllint not installed"; \
    fi
    @./scripts/echo-colors.sh green "✓ Claude Code lint complete"

# Start LocalStack cloud services (auto-detects platform)
cloud-up:
    devbox run cloud-up

cloud-up-internal:
    @./scripts/echo-colors.sh blue "Starting cloud services..."
    @cd services/cloud && ./up.sh
    @./scripts/echo-colors.sh green "✓ Cloud services started"

# Stop LocalStack cloud services
cloud-down:
    devbox run cloud-down

cloud-down-internal:
    @./scripts/echo-colors.sh yellow "Stopping cloud services..."
    cd services/cloud && docker compose -f docker-compose.cloud.base.yml down

# Build/Pull LocalStack cloud services
cloud-build:
    @./scripts/echo-colors.sh blue "Building/Pulling cloud services..."
    cd services/cloud && docker compose -f docker-compose.cloud.base.yml pull
    @./scripts/echo-colors.sh green "✓ Cloud services built/pulled"

# Start RustFS service only
up-cloud-rustfs:
    @./scripts/echo-colors.sh blue "Starting RustFS service..."
    cd services/cloud/rustfs && docker compose -f docker-compose.rustfs.yml --env-file ../../../{{ENV_FILE}} up -d
    @./scripts/echo-colors.sh green "✓ RustFS service started"
    @echo "Console: http://localhost:9001 (RustFS2026!SecureKey/RustFS2026!SecretPhrase)"

# Stop RustFS service only
down-cloud-rustfs:
    @./scripts/echo-colors.sh yellow "Stopping RustFS service..."
    cd services/cloud/rustfs && docker compose -f docker-compose.rustfs.yml down
    @./scripts/echo-colors.sh green "✓ RustFS service stopped"

# Show RustFS logs
logs-cloud-rustfs:
    @./scripts/echo-colors.sh blue "RustFS service logs:"
    @docker logs -f localnet-rustfs

# Check RustFS health
health-cloud-rustfs:
    @./scripts/echo-colors.sh blue "Checking RustFS health..."
    @docker exec localnet-rustfs curl -f http://127.0.0.1:9000/health && \
    docker exec localnet-rustfs curl -f http://127.0.0.1:9001/rustfs/console/health
    @./scripts/echo-colors.sh green "✓ RustFS is healthy"

# Open shell in RustFS container
shell-cloud-rustfs:
    @./scripts/echo-colors.sh blue "Opening shell in RustFS container..."
    @docker exec -it localnet-rustfs /bin/sh

# Start all app services
up-apps:
    @./scripts/echo-colors.sh blue "Starting app services..."
    @docker compose -f docker-compose.localnet.yml --profile apps --env-file {{ENV_FILE}} --progress=plain up -d
    @./scripts/echo-colors.sh green "✓ App services started"

# Stop app services
down-apps:
    @./scripts/echo-colors.sh yellow "Stopping app services..."
    @docker compose -f docker-compose.localnet.yml --profile apps --env-file {{ENV_FILE}} down
    @./scripts/echo-colors.sh green "✓ App services stopped"

# Aliases for common commands
alias rebuild := clean
alias health := health-check
alias status := ps
alias stop := down
alias start := up
