# Justfile for LocalNet Development Environment
# Migrated from Makefile for better cross-platform compatibility

# Environment variables
set export

# Configuration
ENSURE_NETWORK := "./scripts/ensure-network.py"
NETWORK_NAME := "localnet_default"
ENV_FILE := ".env.local.localnet"
COMPOSE_PARALLEL_LIMIT := "2"

# Docker Compose base command (DRY - used throughout)
DC_LOCAL := "COMPOSE_PARALLEL_LIMIT=" + COMPOSE_PARALLEL_LIMIT + " DOCKER_BUILDKIT=1 docker compose -f docker-compose.localnet.yml --env-file " + ENV_FILE
DC_CLOUD := "COMPOSE_PARALLEL_LIMIT=" + COMPOSE_PARALLEL_LIMIT + " DOCKER_BUILDKIT=1 docker compose -f docker-compose.cloud.yml"

# NX binary detection (DRY - resolves local pnpm bin or global nx)
NX_BIN := if path_exists("./node_modules/.bin/nx") == "true" { "./node_modules/.bin/nx" } else { `command -v nx 2>/dev/null || echo ""` }
NX_AVAILABLE := if NX_BIN != "" { "true" } else { "false" }

# Logging configuration (DRY - all output logged with timestamps)
LOG_DIR := "logs"
LOG_FILE := LOG_DIR / "just.log"
TIMESTAMP := "$(date '+%Y-%m-%d %H:%M:%S')"
DATESTAMP := "$(date '+%Y%m%d')"

# Default recipe when just is run without arguments
default:
    @just --list

# Show this help message
help:
    @./scripts/echo-colors.sh blue "Home Lab In-a-Box - Available Commands"
    @echo ""
    @just --list --unsorted

# Bootstrap recipes (ADR-20260131001 compliance)
bootstrap:
    devbox run bootstrap-internal

bootstrap-internal:
    @./scripts/echo-colors.sh blue "Setting up pnpm and nx..."
    @# Run all pnpm commands in single shell so PATH persists
    @export PNPM_HOME="${PNPM_HOME:-$HOME/.local/share/pnpm}" && \
        export PATH="$PNPM_HOME:$PATH" && \
        (rm -f "$PNPM_HOME/global/5/pnpm-lock.yaml"* 2>/dev/null || true) && \
        mkdir -p "$PNPM_HOME/global/5" "$PNPM_HOME/store" && \
        pnpm config set global-dir "$PNPM_HOME/global" && \
        pnpm config set global-bin-dir "$PNPM_HOME" && \
        pnpm config set store-dir "$PNPM_HOME/store" && \
        pnpm add -g nx && \
        ./scripts/echo-colors.sh green "✓ bootstrap-internal completed"

# Logging helpers (DRY - all tasks log with start/end demarcation)
[private]
log-init:
    @mkdir -p {{LOG_DIR}}
    @touch {{LOG_FILE}}

[private]
log-start task:
    @just log-init
    @echo "" >> {{LOG_FILE}}
    @echo "=== START: {{task}} ===" >> {{LOG_FILE}}
    @echo "Timestamp: $(date '+%Y-%m-%d %H:%M:%S %Z')" >> {{LOG_FILE}}
    @echo "Status: RUNNING" >> {{LOG_FILE}}
    @echo "---" >> {{LOG_FILE}}

[private]
log-end task status="SUCCESS":
    @echo "---" >> {{LOG_FILE}}
    @echo "Timestamp: $(date '+%Y-%m-%d %H:%M:%S %Z')" >> {{LOG_FILE}}
    @echo "Status: {{status}}" >> {{LOG_FILE}}
    @echo "=== END: {{task}} ===" >> {{LOG_FILE}}

[private]
log-exec task *args:
    @just log-start "{{task}}"
    @({{args}} 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && just log-end "{{task}}" "SUCCESS" || (just log-end "{{task}}" "FAILED"; exit 1)

# Helper: Profile-based docker compose operations (DRY)
compose-up-profile profile message:
    @just log-start "up-{{profile}}"
    @./scripts/echo-colors.sh blue "{{message}}..."
    @({{DC_LOCAL}} --profile {{profile}} up -d 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (./scripts/echo-colors.sh green "✓ {{message}} started"; just log-end "up-{{profile}}" "SUCCESS") || (./scripts/echo-colors.sh red "✗ {{message}} failed"; just log-end "up-{{profile}}" "FAILED"; exit 1)

compose-down-profile profile message:
    @just log-start "down-{{profile}}"
    @./scripts/echo-colors.sh yellow "{{message}}..."
    @({{DC_LOCAL}} --profile {{profile}} down 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (./scripts/echo-colors.sh green "✓ {{message}} stopped"; just log-end "down-{{profile}}" "SUCCESS") || (./scripts/echo-colors.sh red "✗ {{message}} failed"; just log-end "down-{{profile}}" "FAILED"; exit 1)

compose-build-profile profile:
    @{{DC_LOCAL}} --profile {{profile}} --progress=plain build

# Build and run base-dev and dependencies
# Builds services sequentially to avoid parallel build conflicts with slow Kali images
base-up:
    devbox run base-up-internal

base-up-internal:
    @just log-start "base-up"
    @./scripts/echo-colors.sh blue "Creating base containers..."
    # TODO: Migrate to Docker Compose additional_contexts for native build dependency
    # when supported by OrbStack, Podman, Colima, and Lima. Current profile-based
    # sequencing ensures build order without requiring BuildKit. See AGENTS.md
    # "Build Order vs Runtime Dependencies" section for details.
    @(COMPOSE_PARALLEL_LIMIT={{COMPOSE_PARALLEL_LIMIT}} DOCKER_BUILDKIT=1 docker compose -f docker-compose.shared.yml --env-file {{ENV_FILE}} --progress=plain up -d 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]})

    ## Build remaining base01 services
    @./scripts/echo-colors.sh blue "Building base01 services..."
    @({{DC_LOCAL}} --profile base01 up -d --build 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]})
    ## Build remaining base02 services
    @./scripts/echo-colors.sh blue "Building remaining base02 services..."
    @({{DC_LOCAL}} --profile base02 up -d --build 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]})
    ## Build base03 services (base-dev depends on base-kalinix)
    @./scripts/echo-colors.sh blue "Building base03 services..."
    @({{DC_LOCAL}} --profile base03 up -d --build 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]})
    @./scripts/echo-colors.sh green "✓ base containers created"
    @just log-end "base-up" "SUCCESS"

# Build all Docker images
build:
    devbox run build-internal

build-internal:
    @just log-start "build"
    just base-up-internal
    @./scripts/echo-colors.sh blue "Building all Docker images..."
    @({{DC_LOCAL}} --profile all --progress=plain build 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (./scripts/echo-colors.sh green "✓ Build complete"; just log-end "build" "SUCCESS") || (./scripts/echo-colors.sh red "✗ Build failed"; just log-end "build" "FAILED"; exit 1)

# Build specific service with no cache
build-service service:
    devbox run build-service-internal {{service}}

build-service-internal service:
    @just log-start "build-{{service}}"
    @./scripts/echo-colors.sh blue "Building service {{service}}..."
    @({{DC_LOCAL}} --progress=plain build {{service}} 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (./scripts/echo-colors.sh green "✓ Service {{service}} built"; just log-end "build-{{service}}" "SUCCESS") || (./scripts/echo-colors.sh red "✗ Service {{service}} build failed"; just log-end "build-{{service}}" "FAILED"; exit 1)

