# Multi-profile combinations
up-core-nix:
    devbox run up-core-nix

up-core-nix-internal:
    @./scripts/echo-colors.sh blue "Starting core infrastructure + Nix..."
    @docker compose -f docker-compose.localnet.yml --profile core --profile nix up -d
