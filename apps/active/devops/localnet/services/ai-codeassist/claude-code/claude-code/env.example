# Claude Code Integration Environment Configuration Template
# Copy this file to .env and customize for your environment

# ============================================================================
# Claude Code Integration Configuration
# ============================================================================

# Claude API Configuration
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Claude Code JWT Secret (generate a secure random string)
# You can generate one with: openssl rand -hex 32
CLAUDE_CODE_JWT_SECRET=your_secure_jwt_secret_here

# Claude Code Database Password
# Use a strong password for PostgreSQL database
CLAUDE_CODE_DB_PASSWORD=your_secure_db_password_here

# ============================================================================
# Network Configuration (if running standalone)
# ============================================================================

# If running Claude Code services independently of the main localnet stack,
# you may need to adjust these network settings:

# Local network subnet (should match your Docker network)
# CLAUDE_CODE_NETWORK_SUBNET=172.20.0.0/16

# ============================================================================
# Service Configuration (Optional overrides)
# ============================================================================

# Default model for Claude Code
# CLAUDE_CODE_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Maximum tokens per request
# CLAUDE_CODE_MAX_TOKENS=4096

# Session timeout in hours
# CLAUDE_CODE_SESSION_TIMEOUT_HOURS=24

# ============================================================================
# Development/Testing Configuration
# ============================================================================

# Enable debug logging
# CLAUDE_CODE_DEBUG=false

# API rate limits (requests per minute/hour)
# CLAUDE_CODE_RATE_LIMIT_RPM=100
# CLAUDE_CODE_RATE_LIMIT_RPH=1000

# ============================================================================
# Security Notes
# ============================================================================
# - Never commit the .env file to version control
# - Use strong, unique passwords for all secrets
# - Rotate API keys and secrets regularly
# - Store backups of sensitive configuration securely

# For development/testing, you can use the test API key: sk-test-1234567890abcdef
# This is configured in cc-tools-config/api-keys.json for immediate testing
