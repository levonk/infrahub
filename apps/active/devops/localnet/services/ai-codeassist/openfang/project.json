{
  "name": "localnet-codeassist-openfang",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/ai-codeassist/openfang",
  "tags": ["base", "dev", "docker"],
  "implicitDependencies": ["localnet-base-dev"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/ai-codeassist/openfang",
        "file": "services/ai-codeassist/openfang/Dockerfile.openfang",
        "tags": ["localnet-codeassist-openfang:latest"],
        "push": false,
        "load": true
      }
    }
  }
}
