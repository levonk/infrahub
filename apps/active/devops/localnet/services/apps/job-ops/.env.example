# JobOps Service Environment Variables
# Copy this to your localnet env.local file and configure as needed

# Network Configuration
APPS_JOB_OPS_IP=172.20.255.72
APPS_JOB_OPS_HOST_PORT=3005
APPS_JOB_OPS_CONTAINER_PORT=3005

# Demo Mode (sandbox deployments)
# Set to true for read-only demo mode with auto-reset every 6 hours
APPS_JOB_OPS_DEMO_MODE=false

# Gmail OAuth Configuration (Optional - for tracking inbox)
# Required for Gmail integration to track recruitment emails
# See: https://jobops.dakheera47.com/docs/getting-started/gmail-oauth-setup
APPS_JOB_OPS_GMAIL_OAUTH_CLIENT_ID=
APPS_JOB_OPS_GMAIL_OAUTH_CLIENT_SECRET=
APPS_JOB_OPS_GMAIL_OAUTH_REDIRECT_URI=http://localhost:3005/oauth/gmail/callback

# Basic Auth (Optional - for older single-user installs)
# Only needed for migrating older single-user installations
APPS_JOB_OPS_BASIC_AUTH_USER=
APPS_JOB_OPS_BASIC_AUTH_PASSWORD=

# Self-Hosted Reactive Resume (Optional)
# Configure if you self-host Reactive Resume instead of using the cloud service
APPS_JOB_OPS_RXRESUME_URL=
APPS_JOB_OPS_RXRESUME_API_KEY=
