# Nuxt Tweet Organizer Service - Standard Developer UX Flow
# Following ADR-20260131001 Standard Developer UX Flow

# Default target
default:
    @echo "Available targets:"
    @echo "  up          - Start the service"
    @echo "  down        - Stop the service"
    @echo "  build       - Build the Docker image"
    @echo "  rebuild     - Rebuild the Docker image"
    @echo "  logs        - Show service logs"
    @echo "  health      - Check service health"
    @echo "  shell       - Open shell in container"
    @echo "  test        - Run tests"
    @echo "  clean       - Clean up containers and images"
    @echo "  bootstrap   - Bootstrap the service"

# Normal targets - Developer interface (REQUIRED)
up:
    @echo "🚀 Starting Nuxt Tweet Organizer service..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet up -d
    @echo "✅ Service started at http://localhost:${APPS_NUXT_TWEET_ORG_HOST_PORT:-3000}"

down:
    @echo "🛑 Stopping Nuxt Tweet Organizer service..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet down
    @echo "✅ Service stopped"

build:
    @echo "🔨 Building Nuxt Tweet Organizer image..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet build
    @echo "✅ Build complete"

rebuild:
    @echo "🔨 Rebuilding Nuxt Tweet Organizer image..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet build --no-cache
    @echo "✅ Rebuild complete"

logs:
    @echo "📋 Showing Nuxt Tweet Organizer logs..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet logs -f

health:
    @echo "🏥 Checking Nuxt Tweet Organizer health..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet ps
    @echo ""
    @docker exec localnet-apps-nuxt-tweet-org curl -f http://localhost:${APPS_NUXT_TWEET_ORG_CONTAINER_PORT:-3000} || echo "❌ Service not responding"

shell:
    @echo "🐚 Opening shell in Nuxt Tweet Organizer container..."
    @docker exec -it localnet-apps-nuxt-tweet-org /bin/sh

test:
    @echo "🧪 Running Nuxt Tweet Organizer tests..."
    @./tests/test-nuxt-tweet-org.sh

clean:
    @echo "🧹 Cleaning up Nuxt Tweet Organizer..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet down -v
    @docker image prune -f
    @echo "✅ Cleanup complete"

# Bootstrap recipes (REQUIRED)
bootstrap:
    @echo "🚀 Bootstrapping Nuxt Tweet Organizer service..."
    @just setup
    @echo "✅ Bootstrap complete!"

bootstrap-internal:
    @echo "🔧 Internal bootstrap logic..."
    @echo "Checking environment..."
    @test -f ../../.env.local.localnet || (echo "❌ Environment file not found: ../../.env.local.localnet" && exit 1)
    @echo "✅ Environment file found"
    @echo "✅ Bootstrap complete!"

# Health and diagnostics (REQUIRED)
doctor:
    @echo "🩺 Running diagnostics for Nuxt Tweet Organizer..."
    @echo "Checking Docker..."
    @docker --version
    @echo "Checking docker-compose..."
    @docker compose version
    @echo "Checking environment file..."
    @test -f ../../.env.local.localnet && echo "✅ Environment file exists" || echo "❌ Environment file missing"
    @echo "Checking required variables..."
    @grep -q "X_CLIENT_ID" ../../.env.local.localnet && echo "✅ X_CLIENT_ID found" || echo "❌ X_CLIENT_ID missing"
    @grep -q "X_CLIENT_SECRET" ../../.env.local.localnet && echo "✅ X_CLIENT_SECRET found" || echo "❌ X_CLIENT_SECRET missing"
    @grep -q "NUXT_SESSION_PASSWORD" ../../.env.local.localnet && echo "✅ NUXT_SESSION_PASSWORD found" || echo "❌ NUXT_SESSION_PASSWORD missing"

# Quality checks (OPTIONAL but RECOMMENDED)
quality:
    @echo "🔍 Running quality checks..."
    @just lint
    @just test
    @just health

# Language-specific commands (OPTIONAL)
lint:
    @echo "🔍 Linting Docker configuration..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet config --quiet

# Development setup (OPTIONAL)
setup:
    @echo "🛠️ Setting up development environment..."
    @echo "Checking pnpm-sidecar dependency..."
    @docker network inspect localnet > /dev/null 2>&1 || (echo "❌ localnet network not found - run from localnet root" && exit 1)
    @docker volume inspect localnet-pnpm-cache > /dev/null 2>&1 || (echo "❌ pnpm-cache volume not found - run from localnet root" && exit 1)
    @echo "✅ Development environment ready!"

# Clean up (OPTIONAL)
clean-internal:
    @echo "🧹 Internal cleanup..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet down
    @docker volume rm nuxt-tweet-org-data 2>/dev/null || true
    @echo "✅ Internal cleanup complete"

# Deep clean (OPTIONAL)
clean-all-internal:
    @echo "🧹 Deep cleanup..."
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet down -v
    @docker image rm localnet-apps-nuxt-tweet-org:latest 2>/dev/null || true
    @echo "✅ Deep cleanup complete"

# Development shortcuts
dev: up
restart: down up
status: health
ps:
    @docker compose -f docker-compose.yml --env-file ../../.env.local.localnet ps

# Production shortcuts
prod-up:
    @echo "🚀 Starting Nuxt Tweet Organizer in production mode..."
    @NODE_ENV=production docker compose -f docker-compose.yml --env-file ../../.env.local.localnet up -d

prod-rebuild:
    @echo "🔨 Rebuilding for production..."
    @NODE_ENV=production docker compose -f docker-compose.yml --env-file ../../.env.local.localnet build --no-cache
    @just prod-up

# Utility targets
env-check:
    @echo "🔍 Checking environment variables..."
    @echo "X_CLIENT_ID: ${X_CLIENT_ID:+SET}"
    @echo "X_CLIENT_SECRET: ${X_CLIENT_SECRET:+SET}"
    @echo "NUXT_SESSION_PASSWORD: ${NUXT_SESSION_PASSWORD:+SET}"
    @echo "APPS_NUXT_TWEET_ORG_HOST_PORT: ${APPS_NUXT_TWEET_ORG_HOST_PORT:-3000}"
    @echo "APPS_NUXT_TWEET_ORG_IP: ${APPS_NUXT_TWEET_ORG_IP:-172.20.255.71}"

# Help target
help:
    @echo "Nuxt Tweet Organizer Service - Standard Developer UX Flow"
    @echo ""
    @echo "Quick start:"
    @echo "  just up          # Start the service"
    @echo "  just logs        # View logs"
    @echo "  just down        # Stop the service"
    @echo ""
    @echo "Development:"
    @echo "  just rebuild     # Rebuild the image"
    @echo "  just test        # Run tests"
    @echo "  just health      # Check health"
    @echo "  just shell       # Open shell"
    @echo ""
    @echo "Environment:"
    @echo "  just doctor      # Check environment"
    @echo "  just env-check   # Show env vars"
    @echo ""
    @echo "Cleanup:"
    @echo "  just clean       # Clean containers"
    @echo "  just clean-all   # Deep clean"
