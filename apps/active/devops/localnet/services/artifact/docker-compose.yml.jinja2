---
# {{ _service_name | title }} Docker Compose Configuration
# Generated secure docker-compose configuration for {{ _service_description | lower }}

version: '3.8'

services:
  {{ _service_name }}:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: {{ _service_name }}
    restart: unless-stopped
    ports:
      - "{{ _service_port }}:{{ _service_port }}"
    environment:
      - NODE_ENV=production
      - SERVICE_NAME={{ _service_name }}
      - SERVICE_PORT={{ _service_port }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ _service_port }}{{ _service_health_endpoint }}"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - {{ _service_name }}-network
{% if _include_ui %}
    depends_on:
      {{ _service_name }}-ui:
        condition: service_healthy

  {{ _service_name }}-ui:
    build:
      context: ./ui
      dockerfile: Dockerfile
    container_name: {{ _service_name }}-ui
    restart: unless-stopped
    ports:
      - "{{ _ui_port }}:{{ _ui_port }}"
    environment:
      - NODE_ENV=production
      - API_URL=http://{{ _service_name }}:{{ _service_port }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ _ui_port }}/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - {{ _service_name }}-network
{% endif %}
{% if _use_traefik %}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{ _service_name }}.rule=Host(`{{ _service_name }}.{{ _domain }}`)"
      - "traefik.http.routers.{{ _service_name }}.tls.certresolver=letsencrypt"
      - "traefik.http.services.{{ _service_name }}.loadbalancer.server.port={{ _service_port }}"
{% if _enable_monitoring %}
      - "traefik.http.middlewares.{{ _service_name }}-metrics.forwardauth.address=http://prometheus:9090"
      - "traefik.http.routers.{{ _service_name }}-metrics.rule=Host(`metrics.{{ _domain }}`)"
{% endif %}
{% endif %}
{% if _enable_monitoring %}
    labels:
      - "prometheus.io/scrape=true"
      - "prometheus.io/port={{ _service_port }}"
      - "prometheus.io/path=/metrics"
{% endif %}

networks:
  {{ _service_name }}-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/16
