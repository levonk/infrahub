{
  "name": "localnet-artifact-nexus",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/artifact/nexus",
  "tags": ["service", "artifact", "repository", "docker"],
  "implicitDependencies": [],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/artifact/nexus/docker",
        "file": "services/artifact/nexus/Dockerfile.nexus",
        "tags": ["localnet-artifact-nexus:latest"],
        "push": false,
        "load": true
      }
    },
    "docker:up": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker compose -f docker-compose.localnet.yml --profile artifact up nexus -d"
        ],
        "cwd": "../../../"
      }
    }
  }
}
