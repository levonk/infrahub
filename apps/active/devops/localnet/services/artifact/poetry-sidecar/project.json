{
  "name": "localnet-artifact-poetry-sidecar",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/artifact/poetry-sidecar",
  "tags": ["service", "artifact", "docker"],
  "implicitDependencies": ["localnet-base-sidecar"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/artifact/poetry-sidecar",
        "file": "services/artifact/poetry-sidecar/Dockerfile.poetry-sidecar",
        "tags": ["localnet-artifact-poetry-sidecar:latest"],
        "push": false,
        "load": true
      }
    }
  }
}
