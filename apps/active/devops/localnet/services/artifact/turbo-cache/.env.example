# Turbo Cache Service Environment Variables
# Copy this file to .env and customize for your environment

# Service Configuration
ARTIFACT_TURBO_CACHE_VERSION=main
ARTIFACT_TURBO_CACHE_CONTAINER_PORT=3654
ARTIFACT_TURBO_CACHE_HOST_PORT=3654
ARTIFACT_TURBO_CACHE_WEB_CONTAINER_PORT=3655
ARTIFACT_TURBO_CACHE_WEB_HOST_PORT=3655
ARTIFACT_TURBO_CACHE_LOG_LEVEL=info

# Resource Limits
ARTIFACT_TURBO_CACHE_CPU_LIMIT=0.5
ARTIFACT_TURBO_CACHE_MEMORY_LIMIT=512M
ARTIFACT_TURBO_CACHE_CPU_RESERVATION=0.1
ARTIFACT_TURBO_CACHE_MEMORY_RESERVATION=128M

# Network Configuration
ARTIFACT_TURBO_CACHE_SUBNET=172.21.255.0/24
ARTIFACT_TURBO_CACHE_GATEWAY=172.21.255.1

# Standard LocalNet Variables
PUID=1000
PGID=1000
TZ=UTC

# Data Paths
VOLUME_BASE_PATH=./volumes
