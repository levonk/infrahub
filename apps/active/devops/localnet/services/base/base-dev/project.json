{
  "name": "localnet-base-dev",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/base/base-dev",
  "tags": ["base", "dev", "docker"],
  "implicitDependencies": ["localnet-base-kalinix"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/base/base-dev",
        "file": "services/base/base-dev/Dockerfile.base-dev",
        "tags": ["localnet-base-dev:latest"],
        "push": false,
        "load": true
      }
    }
  }
}
