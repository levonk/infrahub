# Run base01 profile (debian/alpine/sidecar)
up-base01:
    devbox run up-base01-internal

up-base01-internal:
    @just log-start "up-base01"
    @../../scripts/echo-colors.sh blue "Starting base01 (debian/alpine/sidecar)..."
    @({{DC_BASE}} --profile base01 up -d 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (../../scripts/echo-colors.sh green "✓ base01 started"; just log-end "up-base01" "SUCCESS") || (../../scripts/echo-colors.sh red "✗ base01 failed to start"; just log-end "up-base01" "FAILED"; exit 1)

