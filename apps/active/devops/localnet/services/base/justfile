# Build all base images (profile-based)
build:
    devbox run build-internal

build-internal:
    @just log-start "build"
    @../../scripts/echo-colors.sh blue "Building all base images..."
    # Build base01 (debian/alpine/sidecar)
    @../../scripts/echo-colors.sh blue "Building base01 (debian/alpine/sidecar)..."
    @({{DC_BASE}} --profile base01 build 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]})
    # Build base02 (debnix)
    @../../scripts/echo-colors.sh blue "Building base02 (debnix)..."
    @({{DC_BASE}} --profile base02 build 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]})
    # Build base03 (dev)
    @../../scripts/echo-colors.sh blue "Building base03 (dev)..."
    @({{DC_BASE}} --profile base03 build 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (../../scripts/echo-colors.sh green "✓ All base images built"; just log-end "build" "SUCCESS") || (../../scripts/echo-colors.sh red "✗ Build failed"; just log-end "build" "FAILED"; exit 1)

