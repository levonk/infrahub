# Justfile for Base Images
# Follows ADR-20260131001: Standard Developer UX Flow (devbox → just (*-internal))

# Environment variables
set export

# Configuration
PROJECT_DIR := "../.."
ENV_FILE := "../../.env.local.localnet"
COMPOSE_FILE := "docker-compose.base.yml"
COMPOSE_PARALLEL_LIMIT := "2"
NETWORK_NAME := "localnet_default"

# Docker Compose base command (DRY - used throughout)
DC_BASE := "COMPOSE_PARALLEL_LIMIT=" + COMPOSE_PARALLEL_LIMIT + " DOCKER_BUILDKIT=1 docker compose --project-directory " + PROJECT_DIR + " -f " + COMPOSE_FILE + " --env-file " + ENV_FILE

# Logging configuration (DRY - all output logged with timestamps)
LOG_DIR := "../../logs"
LOG_FILE := LOG_DIR / "base-just.log"
TIMESTAMP := "$(date '+%Y-%m-%d %H:%M:%S')"
DATESTAMP := "$(date '+%Y%m%d')"

# Default recipe when just is run without arguments
default:
    @just --list

# Show this help message
help:
    @../../scripts/echo-colors.sh blue "LocalNet Base Images - Available Commands"
    @echo ""
    @just --list --unsorted

# Logging helpers (DRY - all tasks log with start/end demarcation)
[private]
log-init:
    @mkdir -p {{LOG_DIR}}
    @touch {{LOG_FILE}}

[private]
log-start task:
    @just log-init
    @echo "" >> {{LOG_FILE}}
    @echo "=== START: {{task}} ===" >> {{LOG_FILE}}
    @echo "Timestamp: $(date '+%Y-%m-%d %H:%M:%S %Z')" >> {{LOG_FILE}}
    @echo "Status: RUNNING" >> {{LOG_FILE}}
    @echo "---" >> {{LOG_FILE}}

[private]
log-end task status="SUCCESS":
    @echo "---" >> {{LOG_FILE}}
    @echo "Timestamp: $(date '+%Y-%m-%d %H:%M:%S %Z')" >> {{LOG_FILE}}
    @echo "Status: {{status}}" >> {{LOG_FILE}}
    @echo "=== END: {{task}} ===" >> {{LOG_FILE}}

[private]
log-exec task *args:
    @just log-start "{{task}}"
    @({{args}} 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && just log-end "{{task}}" "SUCCESS" || (just log-end "{{task}}" "FAILED"; exit 1)

# ============================================================================
# Build Targets (Individual Services)
# ============================================================================

# Build base-alpine
build-base-alpine:
    devbox run build-base-alpine-internal

build-base-alpine-internal:
    @just log-start "build-base-alpine"
    @../../scripts/echo-colors.sh blue "Building base-alpine..."
    @({{DC_BASE}} --progress=plain build base-alpine 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (../../scripts/echo-colors.sh green "✓ base-alpine built"; just log-end "build-base-alpine" "SUCCESS") || (../../scripts/echo-colors.sh red "✗ base-alpine build failed"; just log-end "build-base-alpine" "FAILED"; exit 1)

