    @just log-start "up"
    @../../scripts/echo-colors.sh blue "Starting all base services..."
    @({{DC_BASE}} --profile all up -d 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (../../scripts/echo-colors.sh green "✓ All base services started"; just log-end "up" "SUCCESS") || (../../scripts/echo-colors.sh red "✗ Base services failed to start"; just log-end "up" "FAILED"; exit 1)

# ============================================================================
# Management Targets
# ============================================================================

# Stop all base services
down:
    devbox run down-internal

down-internal:
    @just log-start "down"
    @../../scripts/echo-colors.sh yellow "Stopping all base services..."
    @({{DC_BASE}} down 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (../../scripts/echo-colors.sh green "✓ Base services stopped"; just log-end "down" "SUCCESS") || (../../scripts/echo-colors.sh red "✗ Base services failed to stop"; just log-end "down" "FAILED"; exit 1)

# Restart all base services
restart:
    devbox run restart-internal

restart-internal:
    @just log-start "restart"
    @../../scripts/echo-colors.sh yellow "Restarting all base services..."
    @({{DC_BASE}} restart 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (../../scripts/echo-colors.sh green "✓ Base services restarted"; just log-end "restart" "SUCCESS") || (../../scripts/echo-colors.sh red "✗ Base services failed to restart"; just log-end "restart" "FAILED"; exit 1)

# View logs from all base services
logs:
    devbox run logs-internal

logs-internal:
    @{{DC_BASE}} logs --tail=100

# Follow logs from all base services
logs-follow:
    devbox run logs-follow-internal

logs-follow-internal:
    @{{DC_BASE}} logs -f

# Show running containers
ps:
    devbox run ps-internal

ps-internal:
    @{{DC_BASE}} ps

# Health check for base services
health-check:
    devbox run health-check-internal

health-check-internal:
    @../../scripts/echo-colors.sh blue "Checking base service health..."
    @{{DC_BASE}} ps
    @../../scripts/echo-colors.sh green "✓ Health check complete"

# Clean up containers and networks
clean:
    devbox run clean-internal

clean-internal:
    @just log-start "clean"
    @../../scripts/echo-colors.sh yellow "Cleaning up base containers and networks..."
    @({{DC_BASE}} down --remove-orphans 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (../../scripts/echo-colors.sh green "✓ Cleanup complete"; just log-end "clean" "SUCCESS") || (../../scripts/echo-colors.sh red "✗ Cleanup failed"; just log-end "clean" "FAILED"; exit 1)

# Clean up containers, networks, and volumes
clean-all:
    devbox run clean-all-internal

clean-all-internal:
    @just log-start "clean-all"
    @../../scripts/echo-colors.sh yellow "Cleaning up base containers, networks, and volumes..."
    @({{DC_BASE}} down -v --remove-orphans 2>&1 | tee -a {{LOG_FILE}}; exit ${PIPESTATUS[0]}) && (../../scripts/echo-colors.sh green "✓ Full cleanup complete"; just log-end "clean-all" "SUCCESS") || (../../scripts/echo-colors.sh red "✗ Full cleanup failed"; just log-end "clean-all" "FAILED"; exit 1)

