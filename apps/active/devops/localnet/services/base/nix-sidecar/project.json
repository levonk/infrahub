{
  "name": "localnet-nix-sidecar",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/base/nix-sidecar",
  "tags": ["sidecar", "foundation", "nix", "docker"],
  "implicitDependencies": ["localnet-base-alpine"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/base/nix-sidecar",
        "file": "services/base/nix-sidecar/Dockerfile.nix-sidecar",
        "tags": ["localnet-nix-sidecar:latest"],
        "push": false,
        "load": true
      }
    },
    "docker:up": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker compose -f docker-compose.shared.yml --profile nix up nix-sidecar -d"
        ],
        "cwd": "../../../"
      }
    }
  }
}
