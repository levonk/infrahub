# RustFS Service Environment Variables
# Copy this file to .env and customize for your deployment

# Service Ports
CLOUD_RUSTFS_HOST_PORT=9000
CLOUD_RUSTFS_CONSOLE_HOST_PORT=9001

# Container Ports (internal)
CLOUD_RUSTFS_CONTAINER_PORT=9000
CLOUD_RUSTFS_CONSOLE_CONTAINER_PORT=9001

# S3 Credentials (CHANGE IN PRODUCTION)
CLOUD_RUSTFS_ACCESS_KEY=rustfsadmin
CLOUD_RUSTFS_SECRET_KEY=rustfsadmin

# Storage Paths
CLOUD_RUSTFS_DATA_PATH=./data
CLOUD_RUSTFS_LOGS_PATH=./logs

# TLS Configuration (optional)
CLOUD_RUSTFS_CERTS_PATH=

# Logging
CLOUD_RUSTFS_LOG_LEVEL=info

# Health Check
CLOUD_RUSTFS_HEALTH_TIMEOUT=10

# OpenTelemetry (optional)
CLOUD_RUSTFS_OBS_ENDPOINT=

# Network Configuration
CLOUD_RUSTFS_IP=172.20.255.80
