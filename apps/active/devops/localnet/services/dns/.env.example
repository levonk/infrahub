# DNS service environment configuration
# Copy to .env and customize values for local deployments.

# Host networking configuration
HOST_IP=192.168.1.10

# DNSDist ports
DNS_TRANSPARENT_PORT=5353
DNS_DIRECT_PORT=15353
DNS_DNSDIST_METRICS_HOST_PORT=8083
DNSDIST_METRICS_PORT=8083

# CoreDNS ports
DNS_COREDNS_MAIN_METRICS_HOST_PORT=9153
DNS_COREDNS_MAIN_HEALTH_HOST_PORT=8080

# dnscrypt-proxy port
DNSCRYPT_PROXY_HOST_PORT=5300

# Optional: override default DNS upstreams within dnscrypt-proxy config
# DNSCRYPT_UPSTREAM_RESOLVERS="cloudflare,quad9"
