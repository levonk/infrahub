# Environment Variables Template
# Copy this to .env and customize for your environment

# Service Configuration
SERVICE_NAME=audiobookshelf
SERVICE_PORT=13378
NODE_ENV=production

# Health Check Configuration
SERVICE_HEALTH_ENDPOINT=/health
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# Database Configuration (if applicable)
# DATABASE_URL=postgresql://user:password@db:5432/{{ _service_name }}
# DATABASE_SSL_MODE=require
# DATABASE_CONNECTION_POOL_SIZE=10

# Redis Configuration (if applicable)
# REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# External API Keys (use secure secret management in production)
# API_KEY_1=your_api_key_here
# API_KEY_2=your_api_key_here

# Monitoring Configuration
# PROMETHEUS_METRICS_ENABLED=true
# PROMETHEUS_METRICS_PORT=9090

# Security Configuration
# SECRET_KEY_BASE=generate_a_strong_random_key_here
# JWT_SECRET=generate_a_strong_random_key_here

# Feature Flags
# ENABLE_DEBUG_MODE=false
# ENABLE_CORS=true
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Performance Configuration
# MAX_WORKERS=4
# REQUEST_TIMEOUT=30
# RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# Email Configuration (if applicable)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# FROM_EMAIL=noreply@yourdomain.com

# File Upload Configuration (if applicable)
# UPLOAD_MAX_SIZE=10MB
# UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf
# UPLOAD_DESTINATION=/app/uploads

# Cache Configuration
# CACHE_TTL=3600
# CACHE_BACKEND=redis
# CACHE_PREFIX={{ _service_name }}

# SSL/TLS Configuration
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CA_PATH=/path/to/ca.pem
