%% Update the diagram when adding new containers or dependencies.
graph TD
  host_clients[(Client Hosts)]:::client
  direct_consumers[(Direct NTP Consumers)]:::client
  chronyd[[{{ _chronyd_service_name | default("chronyd") }} Container]]:::service
  upstream[(Authenticated Upstream NTP Servers)]:::dependency
