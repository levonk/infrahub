  chronyd -->|Metrics :9123| monitoring

  classDef client fill:#dbeafe,stroke:#2563eb,color:#0f172a;
  classDef service fill:#dcfce7,stroke:#16a34a,color:#14532d;
  classDef dependency fill:#fef3c7,stroke:#f59e0b,color:#78350f;
