# Ansible Test Runner for Molecule
# Base image matches OCI target (Debian Bookworm)
FROM debian:bookworm-slim

# Install required packages
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    sudo \
    openssh-server \
    systemd \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create test user with passwordless sudo
RUN useradd -m -s /bin/bash cuser && \
    echo "cuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Configure SSH
RUN mkdir -p /home/cuser/.ssh && \
    chmod 700 /home/cuser/.ssh && \
    chown cuser:cuser /home/cuser/.ssh

# Enable systemd for container
ENV container=docker
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]

# Set working directory
WORKDIR /ansible
