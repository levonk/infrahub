---
# Homepage bookmarks.yaml
# Cross-links to other launch pages and external resources.
# Content is variable-driven — define dashboard_homepage_bookmarks in client host_vars.
# See https://gethomepage.dev/configs/bookmarks/

{% for group in dashboard_homepage_bookmarks %}
- {{ group.name }}:
{% for bookmark in group.bookmarks %}
    - {{ bookmark.name }}:
        - href: {{ bookmark.href }}
          icon: {{ bookmark.icon }}
          description: {{ bookmark.description }}
{% endfor %}
{% endfor %}
