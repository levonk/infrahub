---
# Homepage services.yaml
# Static service entries (in addition to Docker-label-discovered services).
# Content is variable-driven — define dashboard_homepage_services in client host_vars.
# See https://gethomepage.dev/configs/services/

{% for group in dashboard_homepage_services %}
- {{ group.name }}:
{% for service in group.services %}
    - {{ service.name }}:
        href: {{ service.href }}
        icon: {{ service.icon }}
        description: {{ service.description }}
{% if service.widget is defined %}
        widget:
          type: {{ service.widget.type }}
          url: {{ service.widget.url }}
{% endif %}
{% endfor %}
{% endfor %}
