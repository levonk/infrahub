---
# Homepage settings.yaml
# Content is variable-driven — define dashboard_homepage_settings in client host_vars.
# See https://gethomepage.dev/configs/settings/

title: "{{ dashboard_homepage_settings.title }}"
description: "{{ dashboard_homepage_settings.description }}"
backgroundImage: ""
theme: "{{ dashboard_homepage_settings.theme }}"
color: "{{ dashboard_homepage_settings.color }}"
icon: "{{ dashboard_homepage_settings.icon }}"
useEqualHeights: true
layout:
{% for group in dashboard_homepage_settings.layout %}
  {{ group.name }}:
    icon: {{ group.icon }}
{% endfor %}
quicklaunch:
  hideInternetSearch: false
  hideVisitURL: false
  searchDescriptions: true
  hideNewTab: false
  hideHelp: false
  hideChangeLayout: false
  hideRefresh: false
  hideConfigure: false
5700: false
