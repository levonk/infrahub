# {{ ansible_managed }}
# OpenSSH server configuration

Port {{ host_os_bootstrap_ssh_port }}
PermitRootLogin {{ host_os_bootstrap_ssh_permit_root_login }}
PasswordAuthentication {{ host_os_bootstrap_ssh_password_auth }}
PubkeyAuthentication {{ host_os_bootstrap_ssh_pubkey_auth }}
AuthenticationMethods {{ host_os_bootstrap_ssh_auth_method }}

# Security hardening
X11Forwarding no
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server

# Host key preferences (ed25519)
HostKey /etc/ssh/ssh_host_ed25519_key
HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-ed25519
PubkeyAcceptedAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-ed25519
