# /etc/nix/nix.conf — Nix configuration
# Generated by Ansible role: nix-installation
# Do not edit manually; changes will be overwritten.

# ---------------------------------------------------------------------------
# Experimental Features
# ---------------------------------------------------------------------------
{% if nix_installation_experimental_features | default([]) | length > 0 %}
experimental-features = {{ nix_installation_experimental_features | join(' ') }}
{% endif %}

# ---------------------------------------------------------------------------
# Extra Nix Configuration
# ---------------------------------------------------------------------------
{% for key, value in nix_installation_extra_nix_conf | default({}) | dictsort %}
{{ key }} = {{ value }}
{% endfor %}
