---
# Authelia configuration
# Managed by Ansible — do not edit manually.

theme: {{ proxy_authelia_theme }}

server:
  address: "tcp://0.0.0.0:{{ proxy_authelia_web_container_port }}"
  buffers:
    read: 4096
    write: 4096
  endpoints:
    enable_pprof: false
    enable_expvars: false
  asset_path: ""

log:
  level: {{ proxy_authelia_log_level }}
  format: text
  file_path: ""
  keep_stdout: true

totp:
  disable: false
  issuer: authelia.com
  algorithm: sha1
  period: 30
  skew: 1
  secret_size: 32

duo_api:
  disable: true

authentication_backend:
  password_reset:
    disable: false
  refresh_interval: 5m
  file:
    path: /config/users_database.yml
    password:
      algorithm: argon2id
      iterations: 1
      key_length: 32
      salt_length: 16
      parallelism: 8
      memory: 64

access_control:
  default_policy: {{ proxy_authelia_default_policy }}
  rules:
{% for rule in proxy_authelia_rules %}
    - domain: {{ rule.domain | quote }}
      policy: {{ rule.policy }}
{% endfor %}

session:
  name: {{ proxy_authelia_session_name }}
  expiration: {{ proxy_authelia_session_expiration }}
  inactivity: {{ proxy_authelia_session_inactivity }}
  same_site: lax
  cookies:
    - name: authelia_session
      domain: {{ ansible_host | default('localhost') }}.local
      same_site: lax
      authelia_url: https://{{ ansible_host | default('localhost') }}.local:{{ proxy_authelia_web_host_port }}
{% if proxy_authelia_session_redis_enabled | bool %}
  redis:
    host: proxy-authelia-redis
    port: {{ proxy_authelia_redis_container_port }}
    password: {{ proxy_authelia_redis_password }}
{% endif %}

regulation:
  max_retries: 3
  find_time: 2m
  ban_time: 10m

storage:
  encryption_key: a_very_long_encryption_key_at_least_20_chars_for_postgres
{% if proxy_authelia_storage_backend == 'postgres' %}
  postgres:
    address: "tcp://{{ proxy_authelia_postgres_host }}:{{ proxy_authelia_postgres_port }}"
    database: {{ proxy_authelia_postgres_database }}
    username: {{ proxy_authelia_postgres_user }}
    password: {{ proxy_authelia_postgres_password }}
{% elif proxy_authelia_storage_backend == 'sqlite' %}
  local:
    path: /config/db.sqlite3
{% endif %}

notifier:
  disable_startup_check: true
