---
# Authelia configuration
# Managed by Ansible — do not edit manually.

theme:
  default_theme: {{ proxy_authelia_theme }}

jwt_secret: {{ proxy_authelia_jwt_secret }}

default_redirection_url: https://{{ ansible_host | default('localhost') }}:{{ proxy_authelia_web_host_port }}

server:
  address: "tcp://0.0.0.0:{{ proxy_authelia_web_container_port }}"
  buffers:
    read: 4096
    write: 4096
  enable_pprof: false
  enable_expvars: false
disable_keepalive: false
  asset_path: ""

log:
  level: {{ proxy_authelia_log_level }}
  format: text
  file_path: ""
  keep_stdout: true

totp:
  disable: false
  issuer: authelia.com
  algorithm: sha1
  period: 30
  skew: 1
  secret_size: 32

duo_api:
  disable: true

authentication_backend:
  disable_reset_password: false
  refresh_interval: 5m
  file:
    path: /config/users_database.yml
    password:
      algorithm: argon2id
      iterations: 1
      key_length: 32
      salt_length: 16
      parallelism: 8
      memory: 64

access_control:
  default_policy: {{ proxy_authelia_default_policy }}
  rules:
{% for rule in proxy_authelia_rules %}
    - domain: {{ rule.domain }}
      policy: {{ rule.policy }}
{% endfor %}

session:
  name: {{ proxy_authelia_session_name }}
  secret: {{ proxy_authelia_session_secret }}
  expiration: {{ proxy_authelia_session_expiration }}
  inactivity: {{ proxy_authelia_session_inactivity }}
  domain: {{ ansible_host | default('localhost') }}
  same_site: lax
{% if proxy_authelia_session_redis_enabled | bool %}
  redis:
    host: proxy-authelia-redis
    port: {{ proxy_authelia_redis_container_port }}
    password: {{ proxy_authelia_redis_password }}
{% endif %}

regulation:
  max_retries: 3
  find_time: 2m
  ban_time: 10m

storage:
  encryption_key: {{ proxy_authelia_storage_encryption_key }}
{% if proxy_authelia_storage_backend == 'sqlite' %}
  local:
    path: /config/db.sqlite3
{% endif %}

notifier:
  disable_startup_check: false
{% if proxy_authelia_notifier_backend == 'filesystem' %}
  filesystem:
    filename: {{ proxy_authelia_notifier_fs_path }}
{% endif %}
