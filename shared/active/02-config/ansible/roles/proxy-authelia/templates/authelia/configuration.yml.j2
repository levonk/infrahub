---
# Authelia configuration
# Managed by Ansible — do not edit manually.

theme: {{ proxy_authelia_theme }}

server:
  address: "tcp://0.0.0.0:{{ proxy_authelia_web_container_port }}"
  buffers:
    read: 4096
    write: 4096
  endpoints:
    enable_pprof: false
    enable_expvars: false
  asset_path: ""

log:
  level: {{ proxy_authelia_log_level }}
  format: {{ proxy_authelia_log_format }}
  file_path: ""
  keep_stdout: true

totp:
  disable: false
  issuer: authelia.com
  algorithm: sha1
  period: 30
  skew: 1
  secret_size: 32

duo_api:
  disable: true

identity_validation:
  reset_password:
    jwt_secret: {{ proxy_authelia_jwt_secret | default('default_jwt_secret_change_in_production_at_least_20_chars') }}

authentication_backend:
  password_reset:
    disable: false
  refresh_interval: 5m
  file:
    path: /config/users_database.yml
    password:
      algorithm: argon2id
      iterations: 1
      key_length: 32
      salt_length: 16
      parallelism: 8
      memory: 64

access_control:
  default_policy: {{ proxy_authelia_default_policy }}
  rules:
{% for rule in proxy_authelia_rules %}
    - domain: {{ rule.domain | quote }}
      policy: {{ rule.policy }}
{% endfor %}

session:
  name: {{ proxy_authelia_session_name }}
  expiration: {{ proxy_authelia_session_expiration }}
  inactivity: {{ proxy_authelia_session_inactivity }}
  same_site: lax
  secret: {{ proxy_authelia_session_secret | default('default_session_secret_change_in_production_at_least_20_chars') }}
  cookies:
    - name: authelia_session
      domain: {{ proxy_authelia_session_domain | default(ansible_host | default('localhost') + '.local') }}
      same_site: lax
      authelia_url: {{ proxy_authelia_url | default('https://oci.local:9091') }}
{% if proxy_authelia_session_redis_enabled | bool %}
  redis:
    host: proxy-authelia-redis
    port: {{ proxy_authelia_redis_container_port }}
    password: {{ proxy_authelia_redis_password }}
{% endif %}

regulation:
  max_retries: 3
  find_time: 2m
  ban_time: 10m

storage:
  encryption_key: {{ proxy_authelia_storage_encryption_key | default('default_encryption_key_change_in_production_at_least_20_chars') }}
{% if proxy_authelia_storage_backend == 'postgres' %}
  postgres:
    address: "tcp://{{ proxy_authelia_postgres_host }}:{{ proxy_authelia_postgres_port }}"
    database: {{ proxy_authelia_postgres_database }}
    username: {{ proxy_authelia_postgres_user }}
    password: {{ proxy_authelia_postgres_password }}
{% elif proxy_authelia_storage_backend == 'sqlite' %}
  local:
    path: /config/db.sqlite3
{% endif %}

notifier:
  disable_startup_check: true
{% if proxy_authelia_notifier_backend == 'smtp' %}
  smtp:
    address: {{ proxy_authelia_smtp_address | default('smtp://localhost:25') }}
    sender: {{ proxy_authelia_smtp_sender | default('authelia@example.com') }}
{% if proxy_authelia_smtp_username is defined %}
    username: {{ proxy_authelia_smtp_username }}
{% endif %}
{% if proxy_authelia_smtp_password is defined %}
    password: {{ proxy_authelia_smtp_password }}
{% endif %}
{% elif proxy_authelia_notifier_backend == 'filesystem' %}
  filesystem:
    filename: {{ proxy_authelia_notifier_fs_path }}
{% endif %}

{% if proxy_authelia_oidc_enabled | bool %}
# ---------------------------------------------------------------------------
# OpenID Connect 1.0 Provider
# Allows relying parties (e.g. LiteLLM) to use Authelia for SSO.
# ---------------------------------------------------------------------------
identity_providers:
  oidc:
    hmac_secret: {{ proxy_authelia_oidc_hmac_secret }}
    jwks:
      - key_id: 'authelia-rs256'
        algorithm: 'RS256'
        use: 'sig'
        key: |
{{ proxy_authelia_oidc_jwks_private_key | indent(10, true) }}
    enable_client_debug_messages: false
    minimum_parameter_entropy: 8
    enforce_pkce: 'public_clients_only'
    lifespans:
      access_token: '1h'
      authorize_code: '1m'
      id_token: '1h'
      refresh_token: '90m'
    clients:
{% for client in proxy_authelia_oidc_clients %}
      - client_id: '{{ client.client_id }}'
        client_name: '{{ client.client_name }}'
        client_secret: '{{ client.client_secret_hash }}'
        public: false
        redirect_uris:
{% for uri in client.redirect_uris %}
          - '{{ uri }}'
{% endfor %}
        scopes:
{% for scope in client.scopes %}
          - '{{ scope }}'
{% endfor %}
        grant_types:
{% for gt in client.grant_types %}
          - '{{ gt }}'
{% endfor %}
        response_types:
{% for rt in client.response_types %}
          - '{{ rt }}'
{% endfor %}
        authorization_policy: '{{ client.authorization_policy | default("two_factor") }}'
        consent_mode: '{{ client.consent_mode | default("auto") }}'
        userinfo_signed_response_alg: '{{ client.userinfo_signing_algorithm | default("none") }}'
{% endfor %}
{% endif %}
