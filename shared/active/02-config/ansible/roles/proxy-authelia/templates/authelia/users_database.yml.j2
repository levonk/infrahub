---
# Authelia users database
# Managed by Ansible — do not edit manually.
# Admin password MUST be a hash generated with: docker run --rm authelia/authelia:latest authelia crypto hash generate argon2 --password 'yourpassword'

users:
  {{ proxy_authelia_admin_user }}:
    displayname: "{{ proxy_authelia_admin_display_name | default('Administrator') }}"
    password: "{{ proxy_authelia_admin_password }}"
    email: {{ proxy_authelia_admin_email | quote }}
    groups:
      - admins
      - users
