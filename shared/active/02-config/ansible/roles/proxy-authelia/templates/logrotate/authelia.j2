# Authelia logrotate configuration
# Managed by Ansible - DO NOT EDIT MANUALLY

/var/log/authelia/*.log {
    daily
    rotate {{ proxy_authelia_log_retention_days }}
    missingok
    notifempty
    compress
    delaycompress
    copytruncate
    create 0644 root root
    sharedscripts
    postrotate
        docker exec proxy-authelia kill -USR1 1 || true
    endscript
}
