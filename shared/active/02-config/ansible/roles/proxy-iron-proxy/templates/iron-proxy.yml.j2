---
# iron-proxy configuration
# This file controls DNS interception, TLS termination, and allowlist rules
# Generated by Ansible - DO NOT EDIT MANUALLY

# DNS server configuration
dns:
  enabled: {% raw %}{{{% endraw %} proxy_iron_proxy_dns_enabled | ternary('true', 'false') {% raw %}}}{% endraw %}
  listen: ":{% raw %}{{{% endraw %} proxy_iron_proxy_dns_container_port {% raw %}}}{% endraw %}"
  # The IP address returned for intercepted DNS queries
  proxy_ip: "{% raw %}{{{% endraw %} proxy_iron_proxy_dns_proxy_ip {% raw %}}}{% endraw %}"
  # Optional upstream DNS resolver for the proxy's own lookups
  upstream_resolver: "{% raw %}{{{% endraw %} proxy_iron_proxy_upstream_dns {% raw %}}}{% endraw %}"
  # Domains to pass through to the OS resolver (everything else resolves to proxy_ip)
  passthrough:
    - "*.internal.corp"
    - "metadata.google.internal"
    - "metadata.oracle.internal"
  # Static DNS records (take precedence over interception and passthrough)
  records:
    - name: "internal.example.com"
      type: A
      value: "10.0.0.5"

# Proxy listener configuration
proxy:
  http_listen: ":{% raw %}{{{% endraw %} proxy_iron_proxy_http_container_port {% raw %}}}{% endraw %}"
  https_listen: ":{% raw %}{{{% endraw %} proxy_iron_proxy_https_container_port {% raw %}}}{% endraw %}"
  # Global body buffer limits for transforms
  max_request_body_bytes: {% raw %}{{{% endraw %} proxy_iron_proxy_max_request_body_bytes {% raw %}}}{% endraw %}
  max_response_body_bytes: {% raw %}{{{% endraw %} proxy_iron_proxy_max_response_body_bytes {% raw %}}}{% endraw %}
  # Cap on how long the proxy waits for upstream response headers
  upstream_response_header_timeout: "{% raw %}{{{% endraw %} proxy_iron_proxy_upstream_timeout {% raw %}}}{% endraw %}"
  
  # CIDRs the proxy refuses to dial upstream (prevents DNS rebinding and IMDS access)
  upstream_deny_cidrs:
    - "169.254.169.254/32"   # AWS / GCP / Azure IPv4 IMDS
    - "fd00:ec2::254/128"    # AWS IPv6 IMDS
    - "127.0.0.0/8"          # IPv4 loopback
    - "::1/128"              # IPv6 loopback

# TLS / MITM configuration
tls:
  mode: "{% raw %}{{{% endraw %} proxy_iron_proxy_tls_mode {% raw %}}}{% endraw %}"
  ca_cert: "/etc/iron-proxy/ca.crt"
  ca_key: "/etc/iron-proxy/ca.key"
  cert_cache_size: {% raw %}{{{% endraw %} proxy_iron_proxy_cert_cache_size {% raw %}}}{% endraw %}
  leaf_cert_expiry_hours: {% raw %}{{{% endraw %} proxy_iron_proxy_leaf_cert_expiry_hours {% raw %}}}{% endraw %}

# Transform configuration
transforms:
  # Allowlist transform - controls which domains/CIDRs are accessible
  - name: allowlist
    config:
      # When true, log requests that would be blocked but allow them through
      warn: {% raw %}{{{% endraw %} proxy_iron_proxy_allowlist_warn | ternary('true', 'false') {% raw %}}}{% endraw %}
      # Simple form: allow all methods and paths to these hosts
      domains:
{% raw %}{%{% endraw %} for domain in proxy_iron_proxy_allowed_domains {% raw %}%}{% endraw %}
        - "{% raw %}{{{% endraw %} domain {% raw %}}}{% endraw %}"
{% raw %}{%{% endraw %} endfor {% raw %}%}{% endraw %}
      cidrs:
{% raw %}{%{% endraw %} for cidr in proxy_iron_proxy_allowed_cidrs {% raw %}%}{% endraw %}
        - "{% raw %}{{{% endraw %} cidr {% raw %}}}{% endraw %}"
{% raw %}{%{% endraw %} endfor {% raw %}%}{% endraw %}
      # Rule form: restrict by method and/or path
      rules:
{% raw %}{%{% endraw %} for rule in proxy_iron_proxy_allowlist_rules {% raw %}%}{% endraw %}
        - host: "{% raw %}{{{% endraw %} rule.host {% raw %}}}{% endraw %}"
          methods: {% raw %}{{{% endraw %} rule.methods | to_json {% raw %}}}{% endraw %}
          paths: {% raw %}{{{% endraw %} rule.paths | to_json {% raw %}}}{% endraw %}
{% raw %}{%{% endraw %} endfor {% raw %}%}{% endraw %}

  # Secrets transform - injects or replaces API keys
  - name: secrets
    config:
      secrets:
{% raw %}{%{% endraw %} if proxy_iron_proxy_openai_enabled {% raw %}%}{% endraw %}
        # OpenAI API key injection
        - source:
            type: env
            var: OPENAI_API_KEY
          inject:
            header: "Authorization"
            formatter: "Bearer {% raw %}{{{% endraw %} .Value {% raw %}}}{% endraw %}"
          rules:
            - host: "api.openai.com"
              methods: ["POST"]
              paths: ["/v1/*"]
{% raw %}{%{% endraw %} endif {% raw %}%}{% endraw %}

{% raw %}{%{% endraw %} if proxy_iron_proxy_anthropic_enabled {% raw %}%}{% endraw %}
        # Anthropic API key replacement
        - source:
            type: env
            var: ANTHROPIC_API_KEY
          replace:
            proxy_value: "{% raw %}{{{% endraw %} proxy_iron_proxy_anthropic_proxy_token {% raw %}}}{% endraw %}"
            match_headers: ["X-Api-Key"]
            require: true
          rules:
            - host: "*.anthropic.com"
              methods: ["POST"]
              paths: ["/v1/messages", "/v1/complete"]
{% raw %}{%{% endraw %} endif {% raw %}%}{% endraw %}

{% raw %}{%{% endraw %} if proxy_iron_proxy_google_enabled {% raw %}%}{% endraw %}
        # Google API key injection
        - source:
            type: env
            var: GOOGLE_API_KEY
          inject:
            query_param: "key"
          rules:
            - host: "*.googleapis.com"
{% raw %}{%{% endraw %} endif {% raw %}%}{% endraw %}

{% raw %}{%{% endraw %} if proxy_iron_proxy_github_enabled {% raw %}%}{% endraw %}
        # GitHub token injection
        - source:
            type: env
            var: GITHUB_TOKEN
          inject:
            header: "Authorization"
            formatter: 'Basic {% raw %}{{{% endraw %} base64 "x-credential:" .Value {% raw %}}}{% endraw %}'
          rules:
            - host: "api.github.com"
{% raw %}{%{% endraw %} endif {% raw %}%}{% endraw %}
