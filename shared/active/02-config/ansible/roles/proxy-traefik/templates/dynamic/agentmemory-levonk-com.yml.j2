# Traefik Dynamic Configuration - agentmemory Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: {{ agentmemory_domain | default('agentmemory.levonk.com') }}
# Security Chain: Authelia (SSO)
# MCP direct access: Tailscale-only via host port 3111 (bypasses Traefik)
# Web viewer runs on port 3113 (restPort+2); REST API on 3111.
# Traefik routes to the viewer port for browser access; the API port is for
# MCP/programmatic access via Tailscale only.
# Uses container name (not hardcoded IP) so it survives container recreation.

http:
  routers:
    # HTTP router (redirects to HTTPS)
    agentmemory-http:
      rule: "Host(`{{ agentmemory_domain | default('agentmemory.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: agentmemory

    # HTTPS router with Authelia middleware (web viewer access)
    agentmemory-https:
      rule: "Host(`{{ agentmemory_domain | default('agentmemory.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - authelia
      service: agentmemory
      tls:
        certResolver: letsencrypt

  services:
    agentmemory:
      loadBalancer:
        servers:
          - url: "http://{{ agentmemory_container_name | default('localnet-agentmemory') }}:{{ agentmemory_viewer_port | default('3113') }}"
        passHostHeader: true

  middlewares:
    # HTTPS redirect middleware
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
