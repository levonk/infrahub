# Traefik Dynamic Configuration - agentmemory Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: {{ agentmemory_domain | default('agentmemory.levonk.com') }}
# Security Chain: Authelia (SSO)
# MCP direct access: Tailscale-only via host port 3111 (bypasses Traefik)

http:
  routers:
    # HTTP router (redirects to HTTPS)
    agentmemory-http:
      rule: "Host(`{{ agentmemory_domain | default('agentmemory.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: agentmemory

    # HTTPS router with Authelia middleware (web viewer access)
    agentmemory-https:
      rule: "Host(`{{ agentmemory_domain | default('agentmemory.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - authelia
      service: agentmemory
      tls:
        certResolver: letsencrypt

  services:
    agentmemory:
      loadBalancer:
        servers:
          - url: "http://{{ agentmemory_container_ip | default('172.31.0.7') }}:{{ agentmemory_container_port | default('3111') }}"
        passHostHeader: true

  middlewares:
    # HTTPS redirect middleware
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
