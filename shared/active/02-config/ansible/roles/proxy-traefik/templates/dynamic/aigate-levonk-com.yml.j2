# Traefik Dynamic Configuration - LiteLLM AI Gateway Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: aigate.levonk.com (Admin UI — SSO-protected)
#         aigate-api.levonk.com (API + Swagger — master_key auth, no Authelia)
# Purpose: LiteLLM AI Gateway (auth, virtual keys, spend tracking, PII guardrail)
# NOTE: Docker provider is disabled in Traefik v3.0; routing is via file provider.
#       The Docker labels on the litellm container are ignored — this file is
#       the single source of truth for the router. See ADR-20260629001.
#       Uses container name (not hardcoded IP) so it survives container recreation.

http:
  routers:
    # === aigate.levonk.com — Admin UI (SSO via Authelia) ===
    litellm-http:
      rule: "Host(`{{ ai_litellm_domain | default('aigate.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: litellm

    litellm-https:
      rule: "Host(`{{ ai_litellm_domain | default('aigate.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - authelia
      service: litellm
      tls:
        certResolver: letsencrypt

    # === aigate-api.levonk.com — API + Swagger (master_key auth, no Authelia) ===
    litellm-api-http:
      rule: "Host(`{{ ai_litellm_api_domain | default('aigate-api.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: litellm

    litellm-api-https:
      rule: "Host(`{{ ai_litellm_api_domain | default('aigate-api.levonk.com') }}`)"
      entryPoints:
        - websecure
      service: litellm
      tls:
        certResolver: letsencrypt

  services:
    litellm:
      loadBalancer:
        servers:
          - url: "http://{{ ai_litellm_container_name | default('litellm') }}:{{ ai_litellm_container_port | default('4000') }}"
        passHostHeader: true
