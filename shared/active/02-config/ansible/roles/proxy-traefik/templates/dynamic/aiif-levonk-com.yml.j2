# Traefik Dynamic Configuration - AI InterFace (Omnigent) Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: {{ aiif_domain | default('aiif.levonk.com') }}
# Public alias "AI InterFace" for the Omnigent agent framework & meta-harness.
# Container name stays "omnigent" (see aigate pattern: LiteLLM container → aigate.levonk.com).
# Security Chain: GeoBlock → CrowdSec Bouncer → Authelia (SSO with 2FA)
# NOTE: Docker provider is disabled in Traefik v3.0; routing is via file provider.
#       The Docker labels on the omnigent container are ignored — this file is
#       the single source of truth for the router. See ADR-20260629001.
#       Uses container name (not hardcoded IP) so it survives container recreation.

http:
  routers:
    # HTTP router (redirects to HTTPS)
    omnigent-http:
      rule: "Host(`{{ aiif_domain | default('aiif.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: omnigent

    # HTTPS router with full security middleware chain
    omnigent-https:
      rule: "Host(`{{ aiif_domain | default('aiif.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - geoblock
        - crowdsec-bouncer
        - authelia
      service: omnigent
      tls:
        certResolver: letsencrypt

  services:
    omnigent:
      loadBalancer:
        servers:
          - url: "http://{{ aiif_container_name | default('omnigent') }}:{{ aiif_container_port | default('8000') }}"
        passHostHeader: true
