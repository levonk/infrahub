# Traefik Dynamic Configuration - OmniRoute AI Gateway Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: airoute.levonk.com
# Purpose: OmniRoute AI Gateway (tier fallback, 9-factor scoring, free-tier draining)
# Security Chain: Authelia
# NOTE: Docker provider is disabled in Traefik v3.0; routing is via file provider.
#       The Docker labels on the omniroute container are ignored — this file is
#       the single source of truth for the router. See ADR-20260629001.
#       Uses container name (not hardcoded IP) so it survives container recreation.

http:
  routers:
    omniroute-http:
      rule: "Host(`{{ ai_omniroute_domain | default('airoute.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: omniroute

    omniroute-https:
      rule: "Host(`{{ ai_omniroute_domain | default('airoute.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - authelia
      service: omniroute
      tls:
        certResolver: letsencrypt

  services:
    omniroute:
      loadBalancer:
        servers:
          - url: "http://{{ ai_omniroute_container_name | default('localnet-ai-omniroute') }}:{{ ai_omniroute_container_port | default('20128') }}"
        passHostHeader: true
