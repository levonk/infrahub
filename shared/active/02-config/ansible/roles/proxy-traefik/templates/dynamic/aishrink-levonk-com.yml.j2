# Traefik Dynamic Configuration - headroom (aishrink) Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: {{ aishrink_domain | default('aishrink.levonk.com') }}
# Security Chain: Authelia (SSO)
# Uses container name (not hardcoded IP) so it survives container recreation.

http:
  routers:
    # HTTP router (redirects to HTTPS)
    aishrink-http:
      rule: "Host(`{{ aishrink_domain | default('aishrink.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: aishrink

    # HTTPS router with Authelia middleware
    aishrink-https:
      rule: "Host(`{{ aishrink_domain | default('aishrink.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - authelia
      service: aishrink
      tls:
        certResolver: letsencrypt

  services:
    aishrink:
      loadBalancer:
        servers:
          - url: "http://headroom:{{ proxy_headroom_container_port | default('8787') }}"
        passHostHeader: true

  middlewares:
    # HTTPS redirect middleware
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
