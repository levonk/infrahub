# Traefik Dynamic Configuration - Authelia Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: auth.levonk.com
# Purpose: Authelia SSO service

http:
  routers:
    # HTTP router (redirects to HTTPS)
    authelia-http:
      rule: "Host(`auth.levonk.com`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: authelia

    # HTTPS router
    authelia-https:
      rule: "Host(`auth.levonk.com`)"
      entryPoints:
        - websecure
      service: authelia
      tls:
        certResolver: letsencrypt

  services:
    authelia:
      loadBalancer:
        servers:
          - url: "http://{{ proxy_authelia_container_ip | default('172.31.0.6') }}:{{ proxy_authelia_web_container_port | default('9091') }}"
        passHostHeader: true