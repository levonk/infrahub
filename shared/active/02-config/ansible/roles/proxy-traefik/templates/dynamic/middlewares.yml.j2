# Traefik Dynamic Configuration - Middlewares
# Generated by Ansible - DO NOT EDIT MANUALLY

http:
  middlewares:
    # Authelia middleware with redirect support
    authelia:
      forwardAuth:
        address: "http://{{ proxy_authelia_container_ip | default('172.31.0.6') }}:9091/api/verify?rd=https://auth.levonk.com"
        trustForwardHeader: true
        authResponseHeaders:
          - Remote-User
          - Remote-Group
          - Remote-Name
          - Remote-Email
          - Authorization
