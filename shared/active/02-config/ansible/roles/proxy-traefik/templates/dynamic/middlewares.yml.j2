# Traefik Dynamic Configuration - Middlewares
# Generated by Ansible - DO NOT EDIT MANUALLY

http:
  middlewares:
    {% if proxy_traefik_geoblock_enabled %}
    # GeoBlock middleware configuration
    geoblock:
      plugin:
        geoblock:
          allowLocalRequests: {{ proxy_traefik_geoblock_allow_local | lower }}
          logLocalRequests: {{ proxy_traefik_geoblock_log_local | lower }}
          api:
            apiURL: {{ proxy_traefik_geoblock_api_url | to_json }}
            format: json
          strict: {{ proxy_traefik_geoblock_strict | lower }}
          silentStartUp: {{ proxy_traefik_geoblock_silent_startup | lower }}
          allow:
            countryCodes:
              {% for country in proxy_traefik_geoblock_allowed_countries %}
              - {{ country | to_json }}
              {% endfor %}
    {% endif %}

    {% if proxy_traefik_crowdsec_enabled %}
    # CrowdSec Bouncer middleware configuration
    crowdsec-bouncer:
      plugin:
        crowdsec-bouncer:
          enabled: {{ proxy_traefik_crowdsec_enabled | lower }}
          crowdsecMode: {{ proxy_traefik_crowdsec_mode | to_json }}
          crowdsecLapiScheme: {{ proxy_traefik_crowdsec_lapi_scheme | to_json }}
          crowdsecLapiHost: {{ proxy_traefik_crowdsec_lapi_host | to_json }}
          crowdsecLapiPort: {{ proxy_traefik_crowdsec_lapi_port }}
          crowdsecLapiTLS:
            caCertPath: {{ proxy_traefik_crowdsec_lapi_ca_cert_path | to_json }}
            certPath: {{ proxy_traefik_crowdsec_lapi_cert_path | to_json }}
            keyPath: {{ proxy_traefik_crowdsec_lapi_key_path | to_json }}
            insecureSkipVerify: {{ proxy_traefik_crowdsec_lapi_insecure_skip_verify | lower }}
          forwardedHeadersHeaderName: {{ proxy_traefik_crowdsec_forwarded_header | to_json }}
          clientTrustedIPs:
            {% for ip in proxy_traefik_crowdsec_trusted_ips %}
            - {{ ip | to_json }}
            {% endfor %}
          updateIntervalSeconds: {{ proxy_traefik_crowdsec_update_interval }}
          defaultDecisionSeconds: {{ proxy_traefik_crowdsec_default_decision_seconds }}
    {% endif %}

    # Authelia middleware (for future integration)
    authelia:
      forwardAuth:
        address: {{ proxy_traefik_authelia_address | to_json }}
        trustForwardHeader: {{ proxy_traefik_authelia_trust_forward_header | lower }}
        authResponseHeaders:
          - Remote-User
          - Remote-Group
          - Remote-Name
          - Remote-Email
