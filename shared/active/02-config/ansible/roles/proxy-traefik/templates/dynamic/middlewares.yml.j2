# Traefik Dynamic Configuration - Middlewares
# Generated by Ansible - DO NOT EDIT MANUALLY

http:
  middlewares:
    # Authelia middleware with redirect support
    authelia:
      forwardAuth:
        address: "http://{{ proxy_authelia_container_name | default('proxy-authelia') }}:9091/api/verify?rd=https://{{ infra_domain_sso_authelia | default('auth.levonk.com') }}"
        trustForwardHeader: true
        authResponseHeaders:
          - Remote-User
          - Remote-Group
          - Remote-Name
          - Remote-Email
          - Authorization

    # HTTP-to-HTTPS redirect (used by per-domain HTTP routers; the web
    # entrypoint also has a global redirect, but routers still need a
    # named middleware to avoid Traefik "undefined middleware" warnings)
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
