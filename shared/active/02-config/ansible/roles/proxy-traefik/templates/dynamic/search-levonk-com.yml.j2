# Traefik Dynamic Configuration - SearXNG Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: search.levonk.com
# Security Chain: GeoBlock → CrowdSec → Authelia
# Tailscale Bypass: No authentication for Tailscale network requests

http:
  routers:
    # HTTP router (redirects to HTTPS)
    searxng-http:
      rule: "Host(`search.levonk.com`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: searxng

    # HTTPS router with Tailscale bypass (no authentication)
    searxng-tailscale:
      rule: "Host(`search.levonk.com`) && ClientIP(`{{ cloud_server_tailscale_subnet | default('100.64.0.0/10') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - forwarded-headers
      service: searxng
      tls:
        certResolver: letsencrypt
      priority: 100

    # HTTPS router with security middleware chain (external access)
    searxng-https:
      rule: "Host(`search.levonk.com`)"
      entryPoints:
        - websecure
      middlewares:
        - forwarded-headers
        - authelia
      service: searxng
      tls:
        certResolver: letsencrypt

  services:
    searxng:
      loadBalancer:
        servers:
          - url: "http://{{ search_searxng_container_ip | default('172.31.0.5') }}:{{ search_searxng_container_port | default('8080') }}"
        passHostHeader: true

  middlewares:
    # HTTPS redirect middleware
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true


