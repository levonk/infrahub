# Traefik Dynamic Configuration - SearXNG Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: search.levonk.com
# Security Chain: GeoBlock → CrowdSec → Authelia
# Tailscale Bypass: No authentication for Tailscale network requests

http:
  routers:
    # HTTP router (redirects to HTTPS)
    searxng-http:
      rule: "Host(`search.levonk.com`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: searxng

    # HTTPS router for Tailscale/NetBird bypass (no authentication, higher priority)
    searxng-tailscale:
      rule: "Host(`search.levonk.com`) && ClientIP(`{{ cloud_server_tailscale_subnet }}`, `{{ cloud_server_netbird_subnet }}`)"
      entryPoints:
        - websecure
      service: searxng
      tls:
        certResolver: letsencrypt
      priority: 100  # Higher priority than searxng-https

    # HTTPS router with security middleware chain (external access)
    searxng-https:
      rule: "Host(`search.levonk.com`)"
      entryPoints:
        - websecure
      middlewares:
        {% if proxy_traefik_geoblock_enabled %}
        - geoblock
        {% endif %}
        {% if proxy_traefik_crowdsec_enabled %}
        - crowdsec-bouncer
        {% endif %}
        - authelia
      service: searxng
      tls:
        certResolver: letsencrypt

  services:
    searxng:
      loadBalancer:
        servers:
          - url: "http://{{ search_searxng_container_ip | default('172.22.0.2') }}:{{ search_searxng_container_port | default('8080') }}"
        passHostHeader: true

  middlewares:
    # HTTPS redirect middleware
    redirect-to-https:
      redirectScheme:
        scheme: https
        permanent: true
