# Traefik Dynamic Configuration - SearXNG Routing
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: search.levonk.com
# Security Chain: Authelia
# NOTE: Docker provider is disabled in Traefik v3.0; routing is via file provider.
#       Uses container name (not hardcoded IP) so it survives container recreation.

http:
  routers:
    # HTTP router (redirects to HTTPS)
    searxng-http:
      rule: "Host(`{{ search_searxng_domain | default('search.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: searxng

    # HTTPS router with Authelia middleware
    searxng-https:
      rule: "Host(`{{ search_searxng_domain | default('search.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - authelia
      service: searxng
      tls:
        certResolver: letsencrypt

  services:
    searxng:
      loadBalancer:
        servers:
          - url: "http://{{ search_searxng_container_name | default('searxng') }}:{{ search_searxng_container_port | default('8080') }}"
        passHostHeader: true
