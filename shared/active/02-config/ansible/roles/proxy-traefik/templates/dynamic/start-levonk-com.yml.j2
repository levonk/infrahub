# Traefik Dynamic Configuration - Homepage (start.levonk.com)
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: start.levonk.com
# Purpose: Homepage startpage with Docker label discovery + service widgets
# Security Chain: Authelia
# NOTE: Docker provider is disabled in Traefik v3.0; routing is via file provider.
#       The Docker labels on the homepage container are ignored — this file is
#       the single source of truth for the router. See ADR-20260629001.

http:
  routers:
    # HTTP router (redirects to HTTPS)
    homepage-http:
      rule: "Host(`{{ dashboard_homepage_domain | default('start.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: homepage

    # HTTPS router
    homepage-https:
      rule: "Host(`{{ dashboard_homepage_domain | default('start.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - authelia
      service: homepage
      tls:
        certResolver: letsencrypt

  services:
    homepage:
      loadBalancer:
        servers:
          - url: "http://{{ dashboard_homepage_container_name | default('homepage') }}:{{ dashboard_homepage_container_port | default('3000') }}"
        passHostHeader: true
