# Traefik Dynamic Configuration - TraLa (start2.levonk.com)
# Generated by Ansible - DO NOT EDIT MANUALLY
# Domain: start2.levonk.com
# Purpose: TraLa — Traefik-native dashboard that auto-discovers HTTP routers
# Security Chain: Authelia
# NOTE: Docker provider is disabled in Traefik v3.0; routing is via file provider.
#       The Docker labels on the trala container are ignored — this file is
#       the single source of truth for the router. See ADR-20260629001.

http:
  routers:
    # HTTP router (redirects to HTTPS)
    trala-http:
      rule: "Host(`{{ dashboard_trala_domain | default('start2.levonk.com') }}`)"
      entryPoints:
        - web
      middlewares:
        - redirect-to-https
      service: trala

    # HTTPS router
    trala-https:
      rule: "Host(`{{ dashboard_trala_domain | default('start2.levonk.com') }}`)"
      entryPoints:
        - websecure
      middlewares:
        - authelia
      service: trala
      tls:
        certResolver: letsencrypt

  services:
    trala:
      loadBalancer:
        servers:
          - url: "http://{{ dashboard_trala_container_name | default('trala') }}:{{ dashboard_trala_container_port | default('8080') }}"
        passHostHeader: true
