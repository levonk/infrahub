# Traefik Dynamic Configuration - API Router with Basic Auth
# Generated by Ansible - DO NOT EDIT MANUALLY
# Exposes api@internal on the traefik-api entrypoint with basic auth.
# Used by TraLa to auto-discover routers. See ADR-20260629001.

http:
  routers:
    traefik-api:
      rule: "PathPrefix(`/api`) || PathPrefix(`/dashboard`)"
      entryPoints:
        - "{{ proxy_traefik_api_entrypoint_name }}"
      middlewares:
        - traefik-api-auth
      service: api@internal

  middlewares:
    traefik-api-auth:
      basicAuth:
        users:
          - "{{ proxy_traefik_api_auth_user }}:{{ proxy_traefik_api_auth_password | password_hash('bcrypt') }}"
