# Traefik Static Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

global:
  checkNewVersion: {{ proxy_traefik_check_new_version | lower }}
  sendAnonymousUsage: {{ proxy_traefik_send_anonymous_usage | lower }}

# API and Dashboard configuration
api:
  dashboard: {{ proxy_traefik_dashboard_enabled | lower }}
  insecure: {{ proxy_traefik_dashboard_insecure | lower }}

# Entry points
entryPoints:
  web:
    address: ":{{ proxy_traefik_http_container_port }}"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true

  websecure:
    address: ":{{ proxy_traefik_https_container_port }}"
    http:
      tls: true

{% if proxy_traefik_metrics_enabled %}
  metrics:
    address: ":{{ proxy_traefik_metrics_container_port }}"
{% endif %}

# Docker provider
providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: {{ proxy_traefik_docker_expose_default | lower }}
    network: "{{ proxy_traefik_network_name }}"

  file:
    directory: /etc/traefik/dynamic
    watch: {{ proxy_traefik_dynamic_config_watch | lower }}

# Experimental plugins DISABLED - Traefik v3.0 cannot download plugins from GitHub
# Using standalone CrowdSec container instead of Traefik plugins

# ACME/Let's Encrypt configuration
{% if proxy_traefik_acme_enabled %}
certificatesResolvers:
  letsencrypt:
    acme:
      email: {{ proxy_traefik_acme_email | to_json }}
      storage: /letsencrypt/acme.json
      dnsChallenge:
        provider: {{ proxy_traefik_acme_dns_provider | to_json }}
        delayBeforeCheck: {{ proxy_traefik_acme_delay_before_check }}
        resolvers:
          - "{{ proxy_traefik_acme_resolver_1 }}"
          - "{{ proxy_traefik_acme_resolver_2 }}"
{% if proxy_traefik_acme_staging %}
      caServer: https://acme-staging-v02.api.letsencrypt.org/directory
{% else %}
      caServer: https://acme-v02.api.letsencrypt.org/directory
{% endif %}
{% endif %}

# Logging configuration
log:
  level: {{ proxy_traefik_log_level | to_json }}
  filePath: /var/log/traefik/traefik.log
  format: {{ proxy_traefik_log_format | to_json }}

accessLog:
  filePath: /var/log/traefik/access.log
  format: {{ proxy_traefik_access_log_format | to_json }}
  fields:
    headers:
      defaultMode: keep
      names:
        User-Agent: keep
        Authorization: drop
        Content-Type: keep

# Metrics configuration
{% if proxy_traefik_metrics_enabled %}
metrics:
  prometheus:
    entryPoint: metrics
    addEntryPointsLabels: true
    addServicesLabels: true
{% endif %}
