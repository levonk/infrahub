---
# SearXNG Docker Compose Configuration
# Privacy-respecting metasearch engine - routes through NordVPN, exposed via Traefik
# Generated by Ansible

x-logging: &default-logging
  driver: "json-file"
  options:
    max-size: "10m"
    max-file: "5"
    tag: "{{.Name}}"
    labels: "service"

services:
  searxng:
    image: {{ search_searxng_image }}:{{ search_searxng_image_tag }}
    container_name: {{ search_searxng_container_name }}
    restart: unless-stopped
    logging: *default-logging
    user: "{{ search_searxng_puid }}:{{ search_searxng_pgid }}"
    read_only: {{ search_searxng_read_only }}
    tmpfs:
      - /tmp
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    ports:
      - "{{ search_searxng_host_ip }}:{{ search_searxng_host_port }}:{{ search_searxng_container_ip }}:{{ search_searxng_container_port }}"
    environment:
      - PUID={{ search_searxng_puid }}
      - PGID={{ search_searxng_pgid }}
      - TZ={{ search_searxng_tz }}
      - SEARXNG_BIND_ADDRESS={{ search_searxng_container_ip }}
      - SEARXNG_PORT={{ search_searxng_container_port }}
      - HTTP_PROXY={{ search_searxng_http_proxy }}
      - HTTPS_PROXY={{ search_searxng_https_proxy }}
    volumes:
      - {{ search_searxng_config_volume }}:/etc/searxng
      - {{ search_searxng_cache_volume }}:/var/cache/searxng
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ search_searxng_container_port }}{{ search_searxng_health_endpoint }}"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - {{ search_searxng_network_name }}
      - {{ search_searxng_vpn_network }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.searxng.rule=PathPrefix(`/searxng`)"
      - "traefik.http.routers.searxng.entryPoints=websecure"
      - "traefik.http.routers.searxng.middlewares=strip-searxng"
      - "traefik.http.services.searxng.loadbalancer.server.port={{ search_searxng_container_port }}"
      - "traefik.http.middlewares.strip-searxng.stripprefix.prefixes=/searxng"

volumes:
  {{ search_searxng_config_volume }}:
    external: false
  {{ search_searxng_cache_volume }}:
    external: false

networks:
  {{ search_searxng_network_name }}:
    driver: bridge
    ipam:
      config:
        - subnet: 172.22.0.0/16
  {{ search_searxng_vpn_network }}:
    external: true
    name: {{ search_searxng_vpn_network }}