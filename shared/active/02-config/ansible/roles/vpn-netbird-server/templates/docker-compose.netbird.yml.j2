---
# Netbird VPN Docker Compose Configuration
# Generated by Ansible from template

services:
  vpn-netbird:
    image: {{ vpn_netbird_image }}
    container_name: {{ vpn_netbird_container_name }}
    restart: unless-stopped
    ports:
      - "{{ vpn_netbird_port }}:8084"
    environment:
      - NODE_ENV=production
      - SERVICE_NAME=vpn-netbird
      - SERVICE_PORT={{ vpn_netbird_port }}
      - NETBIRD_SETUP_KEY=${NETBIRD_SETUP_KEY}
      - NETBIRD_MANAGEMENT_URL=${NETBIRD_MANAGEMENT_URL}
      - NETBIRD_HOSTNAME=${NETBIRD_HOSTNAME}
      - TZ=${TZ}
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8084/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    volumes:
      - {{ vpn_netbird_config_volume_name }}:/etc/service/config
      - {{ vpn_netbird_data_volume_name }}/var/lib/netbird
    networks:
      - vpn-netbird-network

networks:
  vpn-netbird-network:
    driver: bridge
