{
  "dashboard": {
    "title": "NTP Synchronization",
    "tags": ["homelab", "ntp", "time"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "NTP Offset",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "chronyd_system_offset_seconds",
            "legendFormat": "System Offset",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Offset"},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [0.01], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "NTP Offset Alert",
          "noDataState": "no_data",
          "notifications": [],
          "message": "NTP offset exceeds 10ms threshold"
        }
      },
      {
        "id": 2,
        "title": "NTP Stratum",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "chronyd_stratum",
            "legendFormat": "Stratum",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "orientation": "auto",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 3},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "NTP Synchronization Status",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "chronyd_synchronized",
            "legendFormat": "Synchronized",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "orientation": "auto",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "Not Synchronized", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "Synchronized", "color": "green"}}, "type": "value"}
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "NTP Root Delay",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "chronyd_root_delay_seconds",
            "legendFormat": "Root Delay",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Delay"},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "NTP Root Dispersion",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "chronyd_root_dispersion_seconds",
            "legendFormat": "Root Dispersion",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Dispersion"},
          {"format": "short"}
        ]
      },
      {
        "id": 6,
        "title": "NTP Frequency Adjustment",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "chronyd_frequency_ppm",
            "legendFormat": "Frequency (ppm)",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ppm", "label": "Frequency"},
          {"format": "short"}
        ]
      },
      {
        "id": 7,
        "title": "NTP Requests",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(chronyd_ntp_requests_total[5m])",
            "legendFormat": "{{mode}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "title": "NTS (Network Time Security) Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "chronyd_nts_enabled",
            "legendFormat": "NTS Enabled",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "orientation": "horizontal",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "NTS Disabled", "color": "yellow"}}, "type": "value"},
              {"options": {"1": {"text": "NTS Enabled", "color": "green"}}, "type": "value"}
            ]
          }
        }
      }
    ]
  }
}
