{
  "dashboard": {
    "title": "Service Logs",
    "tags": ["homelab", "logs", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Log Volume by Service",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum by (container_name) (rate({job=\"docker\"}[5m]))",
            "legendFormat": "{{container_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "logs/s", "label": "Logs/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Log Level Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum by (level) (count_over_time({job=\"docker\"} | json | __error__=\"\" [5m]))",
            "legendFormat": "{{level}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Logs",
        "type": "logs",
        "gridPos": {"h": 12, "w": 24, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "{job=\"docker\"} |= \"error\" or {job=\"docker\"} |= \"ERROR\" or {job=\"docker\"} |= \"fatal\" or {job=\"docker\"} |= \"FATAL\"",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 4,
        "title": "DNS Query Logs",
        "type": "logs",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "{container_name=~\"dnsdist|coredns|dnscrypt-proxy\"}",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 5,
        "title": "Proxy Access Logs",
        "type": "logs",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "{container_name=~\"envoy|squid|privoxy\"}",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 6,
        "title": "Security Events",
        "type": "logs",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 30},
        "targets": [
          {
            "expr": "{job=\"docker\"} |= \"blocked\" or {job=\"docker\"} |= \"denied\" or {job=\"docker\"} |= \"unauthorized\" or {job=\"docker\"} |= \"forbidden\"",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "sortOrder": "Descending"
        }
      },
      {
        "id": 7,
        "title": "Transparent vs Direct Mode Traffic",
        "type": "graph",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40},
        "targets": [
          {
            "expr": "sum by (mode) (count_over_time({job=\"docker\"} | json | mode != \"\" [5m]))",
            "legendFormat": "{{mode}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Count"},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "title": "Recent Application Logs",
        "type": "table",
        "gridPos": {"h": 12, "w": 24, "x": 0, "y": 48},
        "targets": [
          {
            "expr": "{job=\"docker\"}",
            "refId": "A",
            "maxLines": 100
          }
        ],
        "transformations": [
          {
            "id": "labelsToFields",
            "options": {
              "valueLabel": "line"
            }
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "displayName": "Time",
              "desc": true
            }
          ]
        }
      }
    ]
  }
}
