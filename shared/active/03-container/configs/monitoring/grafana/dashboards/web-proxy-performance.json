{
  "dashboard": {
    "title": "Web Proxy Performance",
    "tags": ["homelab", "proxy", "web"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Proxy Request Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(envoy_http_downstream_rq_total[5m])",
            "legendFormat": "Envoy - {{mode}}",
            "refId": "A"
          },
          {
            "expr": "rate(squid_client_http_requests_total[5m])",
            "legendFormat": "Squid",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Proxy Response Time (p95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(envoy_http_downstream_rq_time_bucket[5m]))",
            "legendFormat": "Envoy p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(squid_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "Squid p95",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ms", "label": "Latency"},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [200], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "name": "Proxy Latency Alert",
          "noDataState": "no_data",
          "notifications": []
        }
      },
      {
        "id": 3,
        "title": "Squid Cache Hit Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(squid_cache_hits_total[5m]) / (rate(squid_cache_hits_total[5m]) + rate(squid_cache_misses_total[5m]))",
            "legendFormat": "Cache Hit Rate",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "percentunit", "label": "Hit Rate", "max": 1, "min": 0},
          {"format": "short"}
        ]
      },
      {
        "id": 4,
        "title": "Squid Cache Size",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "squid_cache_size_bytes",
            "legendFormat": "Cache Size",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "bytes", "label": "Size"},
          {"format": "short"}
        ]
      },
      {
        "id": 5,
        "title": "HTTP Status Codes",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "sum by (code) (rate(envoy_http_downstream_rq_xx[5m]))",
            "legendFormat": "{{code}}xx",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Proxy Chain Health",
        "type": "stat",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
        "targets": [
          {
            "expr": "up{job=\"envoy\"}",
            "legendFormat": "Envoy",
            "refId": "A"
          },
          {
            "expr": "up{job=\"squid\"}",
            "legendFormat": "Squid",
            "refId": "B"
          },
          {
            "expr": "up{job=\"privoxy\"}",
            "legendFormat": "Privoxy",
            "refId": "C"
          },
          {
            "expr": "up{job=\"tor\"}",
            "legendFormat": "Tor",
            "refId": "D"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "orientation": "auto",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Bandwidth Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
        "targets": [
          {
            "expr": "rate(envoy_http_downstream_cx_tx_bytes_total[5m])",
            "legendFormat": "Sent",
            "refId": "A"
          },
          {
            "expr": "rate(envoy_http_downstream_cx_rx_bytes_total[5m])",
            "legendFormat": "Received",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "Bps", "label": "Bandwidth"},
          {"format": "short"}
        ]
      },
      {
        "id": 8,
        "title": "Tor Circuit Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "tor_circuits_established",
            "legendFormat": "Tor Circuits Established",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "orientation": "horizontal",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 3}
              ]
            }
          }
        }
      }
    ]
  }
}
