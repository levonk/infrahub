# AI Analytics Pipeline - Environment Variables Template
# Copy this file to .env and update with your values

# Database Configuration
ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_USER=analytics
ANALYTICS_DB_PASSWORD=change_me_in_production
ANALYTICS_DB_CONTAINER_IP=172.27.0.10

# Message Queue Configuration
ANALYTICS_QUEUE_CONTAINER_IP=172.27.0.20

# Collector Service Configuration
ANALYTICS_COLLECTOR_CONTAINER_IP=172.27.0.30

# Processor Service Configuration
ANALYTICS_PROCESSOR_CONTAINER_IP=172.27.0.40

# API Service Configuration
ANALYTICS_API_CONTAINER_IP=172.27.0.50
ANALYTICS_API_HOST_PORT=8080
ANALYTICS_API_CONTAINER_PORT=8080
ANALYTICS_API_SECRET_KEY=change_me_in_production_use_strong_random_string

# Logging Configuration
ANALYTICS_LOG_LEVEL=INFO

# Docker Network Configuration
DOCKER_NETWORK_GATEWAY=172.26.0.1

# Development Settings
# Set to true for development mode
DEV_MODE=false

# Data Retention (days)
DATA_RETENTION_DAYS=90

# Analytics Processing
# Batch size for processing analytics events
ANALYTICS_BATCH_SIZE=1000
# Processing interval in seconds
ANALYTICS_PROCESSING_INTERVAL=60

# API Rate Limiting
# Requests per minute per IP
API_RATE_LIMIT=100

# Dashboard Configuration
DASHBOARD_HOST_PORT=3000
DASHBOARD_CONTAINER_PORT=3000
