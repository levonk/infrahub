# FastCode Service Environment Configuration
# Copy this file to .env and customize for your environment

# ===== Service Configuration =====
# Service port and host
FASTCODE_HOST_PORT=5000
FASTCODE_HOST=0.0.0.0

# ===== User and Permission Configuration =====
# Non-root user configuration
USERNAME=fastcode
PUID=1000
PGID=1000

# ===== LLM Provider Configuration =====
# OpenAI Configuration (Primary)
FASTCODE_OPENAI_API_KEY=your_openai_api_key_here
FASTCODE_MODEL=gpt-4
FASTCODE_BASE_URL=https://api.openai.com/v1

# Alternative LLM Providers (uncomment to use)
# OpenRouter Configuration
# FASTCODE_OPENAI_API_KEY=your_openrouter_api_key_here
# FASTCODE_MODEL=google/gemini-3-flash-preview
# FASTCODE_BASE_URL=https://openrouter.ai/api/v1

# Ollama Local Configuration
# FASTCODE_OPENAI_API_KEY=ollama
# FASTCODE_MODEL=qwen3-coder-30b_fastcode
# FASTCODE_BASE_URL=http://localhost:11434/v1

# ===== Nanobot Model Configuration =====
# For agent reasoning and Feishu conversations
FASTCODE_NANOBOT_MODEL=minimax/minimax-m2.1

# ===== Repository Configuration =====
# Mount external repositories (optional)
# FASTCODE_REPO_MOUNT=/path/to/your/repositories

# ===== Performance Configuration =====
# Python optimization
PYTHONUNBUFFERED=1
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1

# ===== Logging Configuration =====
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file location
LOG_FILE=/app/logs/fastcode.log

# ===== Security Configuration =====
# CORS settings
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ===== Resource Limits =====
# Memory and CPU limits (container overrides)
MAX_MEMORY=4G
MAX_CPUS=2.0

# ===== Development Configuration =====
# Debug mode (disable in production)
DEBUG=false

# Reload on code changes (development only)
RELOAD=false

# ===== Monitoring Configuration =====
# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Metrics collection
METRICS_ENABLED=true
METRICS_PORT=9090

# ===== Backup Configuration =====
# Data backup settings
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

# ===== External Services =====
# Redis configuration (optional, for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Vector database configuration
VECTOR_DB_TYPE=chromadb
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8000

# ===== Feature Flags =====
# Enable/disable specific features
FEATURE_MULTI_TURN=true
FEATURE_BATCH_PROCESSING=true
FEATURE_CODE_INDEXING=true
FEATURE_WEB_UI=true
