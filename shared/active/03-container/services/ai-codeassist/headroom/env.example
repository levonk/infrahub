# Environment Variables Template
# Copy this to .env and customize for your environment

# Service Configuration
AI_CODEASSIST_HEADROOM_SERVICE_NAME=headroom
AI_CODEASSIST_HEADROOM_SERVICE_PORT=8787
AI_CODEASSIST_HEADROOM_PUID=1000
AI_CODEASSIST_HEADROOM_PGID=1000
AI_CODEASSIST_HEADROOM_TZ=UTC
AI_CODEASSIST_HEADROOM_HOST_IP=0.0.0.0
AI_CODEASSIST_HEADROOM_HOST_PORT=8787
AI_CODEASSIST_HEADROOM_CONTAINER_IP=0.0.0.0
AI_CODEASSIST_HEADROOM_CONTAINER_PORT=8787

# Headroom Configuration
HEADROOM_PORT=8787
HEADROOM_HOST=0.0.0.0
HEADROOM_DATA_DIR=/data

# Upstream Proxy Configuration
# Points to iron-proxy for the proxy chain: headroom -> iron-proxy -> internet
AI_CODEASSIST_HEADROOM_UPSTREAM_PROXY=http://iron-proxy:8080

# Output Token Reduction
# Set to 1 to enable output token reduction (reduces what the model writes back)
AI_CODEASSIST_HEADROOM_OUTPUT_SHAPER=0

# Health Check Configuration
AI_CODEASSIST_HEADROOM_SERVICE_HEALTH_ENDPOINT=/health
AI_CODEASSIST_HEADROOM_HEALTH_CHECK_INTERVAL=30s
AI_CODEASSIST_HEADROOM_HEALTH_CHECK_TIMEOUT=10s
AI_CODEASSIST_HEADROOM_HEALTH_CHECK_RETRIES=3

# Logging Configuration
AI_CODEASSIST_HEADROOM_LOG_LEVEL=info
AI_CODEASSIST_HEADROOM_LOG_FORMAT=json

# Network Configuration
# Tailscale clients will connect to headroom on the exposed port
# Headroom then forwards to iron-proxy for egress filtering
HEADROOM_TAILSCALE_PORT=8787