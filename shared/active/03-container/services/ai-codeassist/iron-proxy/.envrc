#!/usr/bin/env bash
# direnv configuration for 

# Include shared environment setup
#!/usr/bin/env bash
# Shared direnv environment setup for 

# Use strict mode
set -euo pipefail

# Log direnv loading
if [[ -n "${DIRENV_DEBUG:-}" ]]; then
    echo "direnv: Loading  environment"
fi

# Add local bin to PATH if it exists
if [ -d "/node_modules/.bin" ]; then
    PATH_add "/node_modules/.bin"
fi

# Add local bin to PATH if it exists
if [ -d "/.local/bin" ]; then
    PATH_add "/.local/bin"
fi

# Export common environment variables
export NODE_ENV="${NODE_ENV:-development}"
export PROJECT_ROOT=""


# Project-specific additions
if [ -f "/.envrc" ]; then
    direnv allow ""
fi
