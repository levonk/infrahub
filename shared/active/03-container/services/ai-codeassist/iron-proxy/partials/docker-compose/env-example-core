# Environment Variables Template
# Copy this to .env and customize for your environment

# Service Configuration
AI_CODEASSIST_IRON_PROXY_SERVICE_NAME=iron-proxy
AI_CODEASSIST_IRON_PROXY_SERVICE_PORT=8080
AI_CODEASSIST_IRON_PROXY_NODE_ENV=production
AI_CODEASSIST_IRON_PROXY_PUID=1000
AI_CODEASSIST_IRON_PROXY_PGID=1000
AI_CODEASSIST_IRON_PROXY_TZ=UTC
AI_CODEASSIST_IRON_PROXY_HOST_IP=0.0.0.0
AI_CODEASSIST_IRON_PROXY_HOST_PORT=8080
AI_CODEASSIST_IRON_PROXY_CONTAINER_IP=0.0.0.0
AI_CODEASSIST_IRON_PROXY_CONTAINER_PORT=8080

# Health Check Configuration
AI_CODEASSIST_IRON_PROXY_SERVICE_HEALTH_ENDPOINT=/health
AI_CODEASSIST_IRON_PROXY_HEALTH_CHECK_INTERVAL=30s
AI_CODEASSIST_IRON_PROXY_HEALTH_CHECK_TIMEOUT=10s
AI_CODEASSIST_IRON_PROXY_HEALTH_CHECK_RETRIES=3

# Logging Configuration
AI_CODEASSIST_IRON_PROXY_LOG_LEVEL=info
AI_CODEASSIST_IRON_PROXY_LOG_FORMAT=json
AI_CODEASSIST_IRON_PROXY_LOG_FILE=/app/logs/app.log

# Database Configuration (if applicable)
# AI_CODEASSIST_IRON_PROXY_DATABASE_URL=postgresql://user:password@db:5432/iron-proxy
# AI_CODEASSIST_IRON_PROXY_DATABASE_SSL_MODE=require
# AI_CODEASSIST_IRON_PROXY_DATABASE_CONNECTION_POOL_SIZE=10

# Valkey / Redis Configuration (if applicable)
# AI_CODEASSIST_IRON_PROXY_REDIS_URL=redis://redis:6379
# AI_CODEASSIST_IRON_PROXY_REDIS_PASSWORD=
# AI_CODEASSIST_IRON_PROXY_REDIS_DB=0

# External API Keys (use secure secret management in production)
# AI_CODEASSIST_IRON_PROXY_API_KEY_1=your_api_key_here
# AI_CODEASSIST_IRON_PROXY_API_KEY_2=your_api_key_here

