# Omnigent Environment Variables
# Copy to .env.omnigent and edit. docker-compose reads .env automatically,
# but this stack uses an explicit env_file override in client deployments.
#
# Secrets (OMNIGENT_DB_PASSWORD, OMNIGENT_OIDC_CLIENT_SECRET,
# OMNIGENT_ACCOUNTS_COOKIE_SECRET, OMNIGENT_ACCOUNTS_INIT_ADMIN_PASSWORD)
# MUST be sourced from the client vault (e.g. levonk vault) at deploy time —
# NEVER commit real values to shared/.

# ── Postgres ─────────────────────────────────────────────
# Required. Internal-only (docker network), but set something non-trivial.
# For client deploys, this is injected from the client Ansible vault.
OMNIGENT_DB_PASSWORD=change-me-please
# OMNIGENT_DB_USER=omnigent
# OMNIGENT_DB_NAME=omnigent

# ── Server ───────────────────────────────────────────────
# Host port the omnigent container is published on. Default 8000.
# OMNIGENT_HOST_PORT=8000
# OMNIGENT_CONTAINER_PORT=8000

# ── Image ────────────────────────────────────────────────
# Pre-built image published to GHCR on every main-branch merge.
# Pin to sha-<short> or vX.Y.Z for reproducible deploys.
# OMNIGENT_IMAGE=ghcr.io/omnigent-ai/omnigent-server
# OMNIGENT_IMAGE_TAG=latest

# ── Auth ─────────────────────────────────────────────────
# Default deploy is multi-user with built-in accounts (OMNIGENT_AUTH_ENABLED=1,
# no OIDC issuer). First boot auto-creates an admin user, prints the password to
# `docker compose logs omnigent`, and saves it to /data/admin-credentials.
# For any deploy behind a public domain you MUST set OMNIGENT_ACCOUNTS_BASE_URL.
#
#   A) Built-in accounts (DEFAULT). Set OMNIGENT_ACCOUNTS_BASE_URL for public deploys.
#   B) Native OIDC (existing IdP). Set OMNIGENT_OIDC_* vars (at minimum OMNIGENT_OIDC_ISSUER).
#   C) Header proxy (oauth2-proxy, ALB OIDC, Cloudflare Access). Set OMNIGENT_AUTH_PROVIDER=header.
#
# OMNIGENT_AUTH_ENABLED is the master switch (defaults to 1 in docker-compose).
# Set to 0 ONLY for single-user local dev — NEVER for shared deploys.
# OMNIGENT_AUTH_ENABLED=1
# OMNIGENT_AUTH_PROVIDER=accounts   # uncomment to force a specific mode

# ── Accounts (active when auth on, no OIDC issuer) ───────
# 32-byte hex cookie secret. Generate with `openssl rand -hex 32`.
# OMNIGENT_ACCOUNTS_COOKIE_SECRET=<64-hex-chars>
# Public base URL where users reach the server (behind Traefik/Caddy/ALB).
# OMNIGENT_ACCOUNTS_BASE_URL=https://omnigent.levonk.com
# Pre-seed initial admin password for headless/CI deploys.
# OMNIGENT_ACCOUNTS_INIT_ADMIN_PASSWORD=
# OMNIGENT_ACCOUNTS_SESSION_TTL_HOURS=8
# OMNIGENT_ACCOUNTS_INVITE_TTL_HOURS=72
# OMNIGENT_ACCOUNTS_MAGIC_TTL_MINUTES=10
# OMNIGENT_ACCOUNTS_AUTO_OPEN=0

# ── OIDC (active when auth on + OMNIGENT_OIDC_ISSUER set) ──
# 32-byte random cookie secret in hex. Generate with `openssl rand -hex 32`.
# OMNIGENT_OIDC_COOKIE_SECRET=<64-hex-chars>
# Redirect URI derived from OMNIGENT_DOMAIN as https://<domain>/auth/callback.
# Register that exact URL in your IdP app.
# OMNIGENT_DOMAIN=omnigent.levonk.com
# OMNIGENT_OIDC_ISSUER=https://github.com
# OMNIGENT_OIDC_CLIENT_ID=Iv1.abc123…
# OMNIGENT_OIDC_CLIENT_SECRET=…
# OMNIGENT_OIDC_SCOPES=openid email profile
# OMNIGENT_OIDC_ALLOWED_DOMAINS=example.com,subsidiary.example.com
# OMNIGENT_OIDC_SESSION_TTL_HOURS=8
# OMNIGENT_OIDC_LOGOUT_REDIRECT_URI=https://omnigent.levonk.com/
# OMNIGENT_OIDC_ALLOW_INVITES=1

# ── Traefik / Public Domain ──────────────────────────────
# The Host() rule in traefik labels. Client-specific (override in client overlay).
# OMNIGENT_TRAEFIK_HOST=omnigent.levonk.com

# ── Container Networking ─────────────────────────────────
# Defaults use the 172.36.0.0/16 subnet (omnigent-network).
# OMNIGENT_CONTAINER_IP=172.36.0.10
# OMNIGENT_DB_CONTAINER_IP=172.36.0.20
# OMNIGENT_DB_CONTAINER_NAME=omnigent-postgres
# OMNIGENT_CONTAINER_NAME=omnigent
# OMNIGENT_TRAEFIK_IP=172.31.0.30
