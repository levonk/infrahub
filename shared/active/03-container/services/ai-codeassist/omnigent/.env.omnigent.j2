# Omnigent + Pi Environment Configuration
# Generated by Ansible from .env.omnigent.j2 — DO NOT EDIT MANUALLY
# Secrets sourced from client vault (infrahub-levonk-all.vault.yml)
# Infrastructure vars sourced from shared/levonk infrastructure/*.yml

# ============================================================================
# Omnigent Postgres
# ============================================================================
OMNIGENT_DB_PASSWORD={{ omnigent_db_password }}
OMNIGENT_DB_USER={{ omnigent_db_user | default('omnigent') }}
OMNIGENT_DB_NAME={{ omnigent_db_name | default('omnigent') }}
OMNIGENT_DB_CONTAINER_NAME={{ infra_hostname_omnigent_postgres | default('omnigent-postgres') }}
OMNIGENT_DB_CONTAINER_IP={{ omnigent_db_container_ip | default('172.36.0.20') }}

# ============================================================================
# Omnigent Server
# ============================================================================
OMNIGENT_IMAGE={{ omnigent_image | default('ghcr.io/omnigent-ai/omnigent-server') }}
OMNIGENT_IMAGE_TAG={{ omnigent_image_tag | default('latest') }}
OMNIGENT_CONTAINER_NAME={{ infra_hostname_omnigent | default('omnigent') }}
OMNIGENT_CONTAINER_IP={{ omnigent_container_ip | default('172.36.0.10') }}
OMNIGENT_CONTAINER_PORT={{ infra_port_ai_omnigent_container | default('8000') }}
OMNIGENT_HOST_PORT={{ infra_port_ai_omnigent_host | default('8000') }}
OMNIGENT_TRAEFIK_IP={{ omnigent_traefik_ip | default('172.31.0.30') }}

# ============================================================================
# Omnigent Auth
# ============================================================================
OMNIGENT_AUTH_ENABLED={{ omnigent_auth_enabled | default('1') }}
OMNIGENT_AUTH_PROVIDER={{ omnigent_auth_provider | default('') }}
OMNIGENT_DOMAIN={{ infra_domain_ai_omnigent | default('aiif.levonk.com') }}
OMNIGENT_TRAEFIK_HOST={{ infra_domain_ai_omnigent | default('aiif.levonk.com') }}

# ── Accounts mode (default) ──
OMNIGENT_ACCOUNTS_COOKIE_SECRET={{ omnigent_accounts_cookie_secret }}
OMNIGENT_ACCOUNTS_BASE_URL={{ omnigent_accounts_base_url | default('https://' + (infra_domain_ai_omnigent | default('aiif.levonk.com'))) }}
OMNIGENT_ACCOUNTS_INIT_ADMIN_PASSWORD={{ omnigent_accounts_init_admin_password }}
OMNIGENT_ACCOUNTS_AUTO_OPEN=0

# ── OIDC mode (uncomment/set in vault if using OIDC) ──
OMNIGENT_OIDC_ISSUER={{ omnigent_oidc_issuer | default('') }}
OMNIGENT_OIDC_CLIENT_ID={{ omnigent_oidc_client_id | default('') }}
OMNIGENT_OIDC_CLIENT_SECRET={{ omnigent_oidc_client_secret | default('') }}
OMNIGENT_OIDC_COOKIE_SECRET={{ omnigent_oidc_cookie_secret | default('') }}
OMNIGENT_OIDC_SCOPES={{ omnigent_oidc_scopes | default('') }}
OMNIGENT_OIDC_ALLOWED_DOMAINS={{ omnigent_oidc_allowed_domains | default('') }}

# ============================================================================
# Pi (Coding Agent Harness — RPC mode)
# ============================================================================
PI_API_KEY={{ pi_api_key }}
PI_RPC_PORT={{ infra_port_ai_pi_container | default('8090') }}
PI_HOST_PORT={{ infra_port_ai_pi_host | default('8090') }}
PI_CONTAINER_NAME={{ infra_hostname_pi | default('pi') }}
PI_CONTAINER_IP={{ pi_container_ip | default('172.36.0.30') }}
PI_DASHBOARD_IP={{ pi_dashboard_ip | default('172.35.0.30') }}
PI_CHAIN_IP={{ pi_chain_ip | default('172.29.0.30') }}
PI_PROVIDER={{ pi_provider | default('openai') }}
PI_MODEL={{ pi_model | default('claude-sonnet-4-20250514') }}
# LLM endpoint — pipeline entry (AI Dashboard Proxy 1)
PI_API_BASE_URL={{ pi_api_base_url | default('http://ai-dashboard-proxy-1:8081/v1') }}
PI_SESSION_DIR=/data/sessions
PI_WORKSPACE_DIR=/workspace
PI_PUID=1000
PI_PGID=1000
PI_TZ=UTC
