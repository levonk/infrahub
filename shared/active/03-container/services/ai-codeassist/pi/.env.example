# Pi Environment Variables
# Copy to .env.pi and edit.
#
# Secrets (PI_API_KEY) MUST be sourced from the client Ansible vault at deploy
# time — NEVER commit real values to shared/.

# ── RPC Bridge ───────────────────────────────────────────
# Port the RPC HTTP bridge listens on. Omnigent's runner connects here.
# PI_RPC_PORT=8090
# PI_HOST_PORT=8090

# ── Pi Agent Config ──────────────────────────────────────
# Provider: pi uses a custom "pipeline" provider (see models.json) that points
# at the analytics pipeline entry (AI Dashboard Proxy 1). The pipeline speaks
# OpenAI-compatible API, so pi treats it as an OpenAI provider.
# PI_PROVIDER=openai
# PI_MODEL=claude-sonnet-4-20250514

# Base URL for LLM requests — points at the pipeline entry (AI Dashboard Proxy 1).
# This ensures all pi LLM traffic flows through the analytics pipeline.
# PI_API_BASE_URL=http://ai-dashboard-proxy-1:8081/v1

# API key — injected from vault. Pi passes it through to the pipeline as the
# upstream auth token. The pipeline itself handles real provider auth via
# Iron-Proxy secret injection.
PI_API_KEY=set-me-from-vault

# ── Session Storage ──────────────────────────────────────
# PI_SESSION_DIR=/data/sessions
# PI_NO_SESSION=0  # set to 1 to disable session persistence

# ── Workspace ────────────────────────────────────────────
# Code repos are mounted at /workspace by the runner or client overlay.
# PI_WORKSPACE_DIR=/workspace

# ── User/Group ───────────────────────────────────────────
# PI_PUID=1000
# PI_PGID=1000
# PI_TZ=UTC

# ── Container Networking ─────────────────────────────────
# Defaults use IPs within the omnigent/ai-dashboard/proxy-chain networks.
# PI_CONTAINER_IP=172.36.0.30
# PI_DASHBOARD_IP=172.35.0.30
# PI_CHAIN_IP=172.29.0.30
# PI_CONTAINER_NAME=pi
