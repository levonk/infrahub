# AI Dashboard Pipeline Configuration
# Multi-Stage Analytics Collection Environment Variables
# Pipeline: AI Dashboard Proxy 1 → Privacy Orchestrator → Headroom → OmniRoute → Forge → AI Dashboard Proxy 2 → Iron-Proxy → NordVPN → Internet

# ============================================================================
# AI Dashboard Database Configuration
# ============================================================================
AI_DASHBOARD_DB_CONTAINER_IP={{ ai_dashboard_db_container_ip }}
AI_DASHBOARD_DB_NAME={{ ai_dashboard_db_name }}
AI_DASHBOARD_DB_USER={{ ai_dashboard_db_user }}
AI_DASHBOARD_DB_PASSWORD={{ ai_dashboard_db_password }}
AI_DASHBOARD_DATABASE_URL={{ ai_dashboard_database_url }}

# ============================================================================
# AI Dashboard Proxy Collector 1 - Entry Stage
# ============================================================================
AI_DASHBOARD_PROXY_1_CONTAINER_IP={{ ai_dashboard_proxy_1_container_ip }}
AI_DASHBOARD_PROXY_1_CHAIN_IP={{ ai_dashboard_proxy_1_chain_ip }}
AI_DASHBOARD_PROXY_1_HOST_PORT={{ ai_dashboard_proxy_1_host_port }}
AI_DASHBOARD_PROXY_1_CONTAINER_PORT={{ ai_dashboard_proxy_1_container_port }}

# ============================================================================
# AI Dashboard Proxy Collector 2 - Pre-Egress Stage
# ============================================================================
AI_DASHBOARD_PROXY_2_CONTAINER_IP={{ ai_dashboard_proxy_2_container_ip }}
AI_DASHBOARD_PROXY_2_CHAIN_IP={{ ai_dashboard_proxy_2_chain_ip }}
AI_DASHBOARD_PROXY_2_HOST_PORT={{ ai_dashboard_proxy_2_host_port }}
AI_DASHBOARD_PROXY_2_CONTAINER_PORT={{ ai_dashboard_proxy_2_container_port }}

# ============================================================================
# Privacy Orchestrator - PII Detection and Transformation
# ============================================================================
PRIVACY_ORCHESTRATOR_CONTAINER_IP={{ privacy_orchestrator_container_ip }}
PRIVACY_ORCHESTRATOR_CHAIN_IP={{ privacy_orchestrator_chain_ip }}
PRIVACY_ORCHESTRATOR_HOST_PORT={{ privacy_orchestrator_host_port }}
PRIVACY_ORCHESTRATOR_CONTAINER_PORT={{ privacy_orchestrator_container_port }}
PRIVACY_ORCHESTRATOR_LOG_LEVEL={{ privacy_orchestrator_log_level }}
PRIVACY_ORCHESTRATOR_MODE={{ privacy_orchestrator_mode }}
PRIVACY_ORCHESTRATOR_CONFIG_PATH={{ privacy_orchestrator_config_path }}
PRIVACY_ORCHESTRATOR_DATABASE_URL={{ privacy_orchestrator_database_url }}

# ============================================================================
# Forge - Tool Calling Reliability Layer
# ============================================================================
FORGE_CONTAINER_IP={{ forge_container_ip }}
FORGE_CHAIN_IP={{ forge_chain_ip }}
FORGE_HOST_PORT=8083
FORGE_CONTAINER_PORT={{ forge_container_port }}
FORGE_BACKEND_URL={{ forge_backend_url }}
FORGE_MAX_RETRIES={{ forge_max_retries }}
FORGE_REASONING_REPLAY={{ forge_reasoning_replay }}

# ============================================================================
# General AI Dashboard Configuration
# ============================================================================
AI_DASHBOARD_LOG_LEVEL={{ ai_dashboard_log_level }}
AI_ANALYTICS_PROXY_MODE={{ ai_analytics_proxy_mode }}

# ============================================================================
# Pipeline Stage Configuration
# ============================================================================
# Stage 1: Entry (first stage in pipeline)
AI_ANALYTICS_PROXY_STAGE_1={{ ai_analytics_proxy_stage_1 }}
AI_ANALYTICS_PROXY_COLLECTOR_ID_1={{ ai_analytics_proxy_collector_id_1 }}

# Stage 2: Pre-egress (second-to-last stage, before Iron-Proxy)
AI_ANALYTICS_PROXY_STAGE_2={{ ai_analytics_proxy_stage_2 }}
AI_ANALYTICS_PROXY_COLLECTOR_ID_2={{ ai_analytics_proxy_collector_id_2 }}

# ============================================================================
# Upstream Service Configuration
# ============================================================================
# Headroom compression service
AI_ANALYTICS_UPSTREAM_HEADROOM={{ ai_analytics_upstream_headroom }}

# OmniRoute AI gateway (replaces 9Router)
AI_ANALYTICS_UPSTREAM_OMNIROUTE={{ ai_analytics_upstream_omniroute }}

# Forge tool calling reliability layer
AI_ANALYTICS_UPSTREAM_FORGE=http://forge:8081

# Iron-Proxy egress firewall
AI_ANALYTICS_UPSTREAM_IRON_PROXY={{ ai_analytics_upstream_iron_proxy }}

# NordVPN egress (final stage before internet)
AI_ANALYTICS_UPSTREAM_NORDVPN={{ ai_analytics_upstream_nordvpn }}