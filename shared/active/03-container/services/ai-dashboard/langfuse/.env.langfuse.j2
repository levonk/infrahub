# Langfuse Environment Configuration
# Generated by Ansible from .env.langfuse.j2 — DO NOT EDIT MANUALLY
# Secrets sourced from client vault (infrahub-levonk-all.vault.yml)
# Infrastructure vars sourced from shared/levonk infrastructure/*.yml

# ============================================================================
# Network
# ============================================================================
LANGFUSE_NETWORK_SUBNET={{ infra_network_ai_langfuse_subnet | default('172.37.0.0/16') }}
LANGFUSE_NETWORK_GATEWAY={{ infra_network_ai_langfuse_gateway | default('172.37.0.1') }}

# ============================================================================
# Langfuse PostgreSQL
# ============================================================================
LANGFUSE_POSTGRES_VERSION={{ langfuse_postgres_version | default('17') }}
LANGFUSE_POSTGRES_CONTAINER_NAME={{ infra_hostname_langfuse_postgres | default('langfuse-postgres') }}
LANGFUSE_POSTGRES_CONTAINER_IP={{ infra_network_ip_langfuse_postgres | default('172.37.0.20') }}
LANGFUSE_POSTGRES_USER={{ langfuse_postgres_user | default('langfuse') }}
LANGFUSE_POSTGRES_DB={{ langfuse_postgres_db | default('langfuse') }}
LANGFUSE_POSTGRES_PASSWORD={{ vault_langfuse_postgres_password }}

# ============================================================================
# Langfuse ClickHouse
# ============================================================================
LANGFUSE_CLICKHOUSE_CONTAINER_NAME={{ infra_hostname_langfuse_clickhouse | default('langfuse-clickhouse') }}
LANGFUSE_CLICKHOUSE_CONTAINER_IP={{ infra_network_ip_langfuse_clickhouse | default('172.37.0.30') }}
LANGFUSE_CLICKHOUSE_USER={{ langfuse_clickhouse_user | default('clickhouse') }}
LANGFUSE_CLICKHOUSE_PASSWORD={{ vault_langfuse_clickhouse_password }}
LANGFUSE_CLICKHOUSE_CLUSTER_ENABLED={{ langfuse_clickhouse_cluster_enabled | default('false') }}

# ============================================================================
# Langfuse Redis
# ============================================================================
LANGFUSE_REDIS_CONTAINER_NAME={{ infra_hostname_langfuse_redis | default('langfuse-redis') }}
LANGFUSE_REDIS_CONTAINER_IP={{ infra_network_ip_langfuse_redis | default('172.37.0.40') }}
LANGFUSE_REDIS_AUTH={{ vault_langfuse_redis_auth }}

# ============================================================================
# Langfuse MinIO (S3-compatible blob storage)
# ============================================================================
LANGFUSE_MINIO_CONTAINER_NAME={{ infra_hostname_langfuse_minio | default('langfuse-minio') }}
LANGFUSE_MINIO_CONTAINER_IP={{ infra_network_ip_langfuse_minio | default('172.37.0.50') }}
LANGFUSE_MINIO_ROOT_USER={{ vault_langfuse_minio_root_user }}
LANGFUSE_MINIO_ROOT_PASSWORD={{ vault_langfuse_minio_root_password }}
LANGFUSE_MINIO_HOST_PORT={{ infra_port_ai_langfuse_minio_api_host | default('9190') }}

# ============================================================================
# Langfuse Worker
# ============================================================================
LANGFUSE_WORKER_CONTAINER_NAME={{ infra_hostname_langfuse_worker | default('langfuse-worker') }}
LANGFUSE_WORKER_CONTAINER_IP={{ infra_network_ip_langfuse_worker | default('172.37.0.11') }}

# ============================================================================
# Langfuse Web (UI + Ingestion API)
# ============================================================================
LANGFUSE_WEB_CONTAINER_NAME={{ infra_hostname_langfuse_web | default('langfuse-web') }}
LANGFUSE_WEB_CONTAINER_IP={{ infra_network_ip_langfuse_web | default('172.37.0.10') }}
LANGFUSE_WEB_AIDASHBOARD_IP={{ langfuse_web_aidashboard_ip | default('172.35.0.40') }}
LANGFUSE_WEB_TRAEFIK_IP={{ infra_network_ip_langfuse_traefik | default('172.31.0.40') }}
LANGFUSE_WEB_CONTAINER_PORT={{ infra_port_ai_langfuse_web_container | default('3000') }}
LANGFUSE_WEB_HOST_PORT={{ infra_port_ai_langfuse_web_host | default('3001') }}

# ============================================================================
# Langfuse Auth & Encryption
# ============================================================================
LANGFUSE_SALT={{ vault_langfuse_salt }}
LANGFUSE_ENCRYPTION_KEY={{ vault_langfuse_encryption_key }}
LANGFUSE_NEXTAUTH_SECRET={{ vault_langfuse_nextauth_secret }}
LANGFUSE_NEXTAUTH_URL={{ langfuse_nextauth_url | default('https://' + (infra_domain_ai_langfuse | default('langfuse.levonk.com'))) }}
LANGFUSE_TRAEFIK_HOST={{ infra_domain_ai_langfuse | default('langfuse.levonk.com') }}
LANGFUSE_TELEMETRY_ENABLED={{ langfuse_telemetry_enabled | default('false') }}
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES={{ langfuse_enable_experimental_features | default('false') }}

# ============================================================================
# Langfuse Headless Init (optional — bootstraps org/project/user on first start)
# ============================================================================
LANGFUSE_INIT_ORG_ID={{ vault_langfuse_init_org_id | default('') }}
LANGFUSE_INIT_ORG_NAME={{ vault_langfuse_init_org_name | default('') }}
LANGFUSE_INIT_PROJECT_ID={{ vault_langfuse_init_project_id | default('') }}
LANGFUSE_INIT_PROJECT_NAME={{ vault_langfuse_init_project_name | default('') }}
LANGFUSE_INIT_PROJECT_PUBLIC_KEY={{ vault_langfuse_init_project_public_key | default('') }}
LANGFUSE_INIT_PROJECT_SECRET_KEY={{ vault_langfuse_init_project_secret_key | default('') }}
LANGFUSE_INIT_USER_EMAIL={{ vault_langfuse_init_user_email | default('') }}
LANGFUSE_INIT_USER_NAME={{ langfuse_init_user_name | default('') }}
LANGFUSE_INIT_USER_PASSWORD={{ vault_langfuse_init_user_password | default('') }}
