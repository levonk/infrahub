# OmniRoute Dockerfile
# Based on official image diegosouzapw/omniroute:latest
# Modified to follow localnet security standards

FROM diegosouzapw/omniroute:latest as root-stage

# Switch to root for setup
USER root

# Set up directories with proper permissions
RUN mkdir -p /app/data

# Copy healthcheck script
COPY assets/static/omniroute/healthcheck-omniroute.sh /usr/local/bin/healthcheck-omniroute.sh
RUN chmod +x /usr/local/bin/healthcheck-omniroute.sh

# Copy entrypoint script
COPY assets/static/omniroute/entrypoint-omniroute.sh /usr/local/bin/entrypoint-omniroute.sh
RUN chmod +x /usr/local/bin/entrypoint-omniroute.sh

# Switch back to non-root user for runtime
USER node

# Expose OmniRoute port
EXPOSE 20128

# Health check using localnet healthcheck script
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD /usr/local/bin/healthcheck-omniroute.sh

# Use custom entrypoint
ENTRYPOINT ["/usr/local/bin/entrypoint-omniroute.sh"]
