    "github:agavra/tuicr",
    "github:modem-dev/hunk",

    # Development Infrastructure
    "chezmoi", "universal-ctags",                   # Dotfile management and code indexing

    # Terminal Enhancement
    "nerd-fonts.jetbrains-mono",                    # Terminal fonts

    # CI/CD & Build Tools
    "act",                    # Local GitHub Actions runner

    # Data Visualization & Diagramming
    "graphviz", "plantuml", "mermaid-cli",          # Diagramming tools

    # System Monitoring & Utilities
    "htop", "btop", "bottom", "procs", "dust", "duf",  # System monitors

    # File Management & Archives
    "trash-cli", "p7zip", "unzip", "zip", "rsync",   # File management tools

    # Text Processing & Data Tools
    "jq", "yq-go", "gron", "fx", "tokei",          # JSON/YAML processing and code metrics

    # Network & Security Tools
    "nmap", "tcpdump", "mtr", "whois", "rhash",    # Network analysis and security
    "oniux",                                     # wrap any cli, incl. shell, with a tor exit only option.

    # Data Processing & Databases
    "duckdb", "sqlite",       # Databases
    "postgresql-client", "mysql-client", "redis", "redis-tools", "valkey",  # Database clients
    "pgcli", "mycli", "redis-cli",                 # Database CLI tools

    # AI & Coding Assistants
    "opencode", "gemini-cli", "github-copilot-cli", "cursor-cli", "qwen-code", "amp-cli",  # AI coding assistants
    "claude-code-router", "claude-code", "claude-monitor",  # Claude Code ecosystem

    # Programming Languages & Runtimes
    "nodejs_24",           # Node.js JavaScript runtime
    "python312", "python313", "python314", "python315FreeThreading",  # Python interpreters
    "jdk17",                  # Java Development Kit
    "rustc", "cargo",         # Rust compiler and package manager
    "go",                     # Go programming language
    "swift",                  # Swift programming language
    "kotlin",                 # Kotlin programming language
    "ruby_3_3",           # Ruby interpretersproject
    "php_83",                   # PHP interpreters
    "scala_3",  # Scala programming language
    "powershell", "bash", "zsh", "fish",            # Shell environments

