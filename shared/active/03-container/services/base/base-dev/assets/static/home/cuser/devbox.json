    "npm", "yarn", "pnpm",     # Node.js package managers
    "pip", "poetry", "pipx", "uv",                   # Python package managers
    "bundler",               # Ruby package manager
    "gradle", "maven", "sbt", "mill", "scala-cli",  # JVM build tools
    "cmake", "just", "just-lsp", "vscode-just",        # C/C++ build systems
    "composer", "coursier",   # PHP and Scala package managers
    "swiftPackages.swiftpm",  # Swift Package Manager

    # Web Development & Frontend
    "typescript", "typescript-language-server",     # TypeScript language and LSP
    "tailwindcss_4", "@tailwindcss/language-server",  # Tailwind CSS
    "eslint_d",              # ESLint daemon
    "vscode-extensions.bradlc.vscode-tailwindcss",  # VS Code Tailwind extension
    "ungoogled-chromium",    # Privacy-focused browser
    "playwright-test", "python314Packages.playwright", "python314Packages.playwright-stealth",  # Browser automation

    # Python Development Tools
    "python312Packages.virtualenv", "python313Packages.virtualenv", "python314Packages.virtualenv",  # Virtual environments
    "python312Packages.black", "python313Packages.black", "python314Packages.black",  # Code formatter
    "python312Packages.flake8", "python313Packages.flake8", "python314Packages.flake8",  # Linter
    "python312Packages.mypy", "python313Packages.mypy", "python314Packages.mypy",  # Type checker
    "python312Packages.pytest", "python313Packages.pytest", "python314Packages.pytest",  # Test framework
    "python312Packages.copier",  # Project templating tool

    # Language-Specific Development Tools
    "gopls", "delve", "go-tools",                    # Go LSP, debugger, and tools
    "dotnet-sdk_8", "dotnet-runtime_8", "dotnet-aspnetcore_8",  # .NET 8 SDK and runtime
    "rustfmt", "rust-analyzer",                      # Rust formatter and LSP
    "kotlin-language-server",                        # Kotlin LSP
    "rubyPackages_3_1.rubocop", "rubyPackages_3_2.rubocop", "rubyPackages_3_3.rubocop",  # Ruby linter
    "phpPackages_81.composer", "phpPackages_82.composer", "phpPackages_83.composer",  # PHP package manager
    "phpPackages_81.psalm", "phpPackages_82.psalm", "phpPackages_83.psalm",  # PHP static analysis
    "phpPackages_81.phpstan", "phpPackages_82.phpstan", "phpPackages_83.phpstan",  # PHP static analysis
    "phpPackages_81.xdebug", "phpPackages_82.xdebug", "phpPackages_83.xdebug",  # PHP debugger
    "metals",                 # Scala LSP
    "swiftlint", "swiftformat", "xcodes", "xcodegen", "darwin.xcode",  # Swift and Apple development

    # Mobile Development
    "flutter", "dart-sdk",    # Flutter framework and Dart SDK

    # Infrastructure as Code
    "terraform", "terragrunt", "opentofu",           # IaC tools
    "tflint", "tfsec", "checkov",                    # IaC linting and security
    "pulumi", "pumictl", "pulumiPackages.pulumi-nodejs", "python313Packages.pulumi",  # Pulumi ecosystem

    # C/C++ Development Tools
    "gcc", "clang", "gdb", "lld", "llvm",            # Compilers, debuggers, and toolchains
    "cppcheck", "valgrind", "clang-tools",           # Static analysis and debugging

    #

  ],
  "hooks": {
    "on_create": [
      "curl ifconfig.me"
    ]
  },
  "shell": {
    "init_hook": [
      "echo '🤖 Dev Base: Development environment ready'",
      "cd /home/cuser/project"
    ]
  }
}
