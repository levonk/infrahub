{
  "packages": [
    # Core Development Environment & Package Management
    "nix",                    # Nix package manager (core dependency)
    "devbox",                 # Devbox environment manager (core dependency)

    # Security & Certificates
    "cacert"                 # CA certificates for HTTPS

    # System Essentials
    "file", "findutils", "procps", "shadow", "gosu",  # Core system utilities

    # Shell & Terminal Environment
    "wl-clipboard", "direnv",       # Terminal multiplexer and environment manager
    "fzf", "ast-grep", "eza", "zoxide", # Navigation and search tools
    "atuin", "comby", "tlrc", "pay-respects", "yazi",  # Shell enhancement tools
    "zellij", # Better than `tmux`
    "github:ogulcancelik/herdr", # tmux for AI CodeAssist
    "ripgrep", # Better than `grep`
    "fz", # Better than `find`
    "plocate", # Better than `locate`
    "sd", # Better than `sed`
    "jaq", # Better than `awk` for json only
    "bat", # Better than `less`
    "cargo-binstall", # Better than `cargo install` when you don't need source
    "zsh", # Better than `bash`
    #"uutils", # Better than `coreutils`
    "mtr", # better than `traceroute`
    "ss", # better than `netstat`
    "ip", # better than `ifconfig`
    "dog", # better than `dig`
    "xh", # better than `curl` (for humans)
    "btop", # better than `top`
    "procs", # better than `ps`
    "dust", # better than `du`
    "gping", # better than `ping`
    "dtrx", # better than `tar`
    "7z", # better than `unzip`
    "rsync", # better than `scp`
    "broot", # better than `tree`
    "age", # better than `gpg`
    "gpg-agent", # better than `ssh-agent`
    "buildkit", # better than `ssh-agent`
    "tldr", # better than `man`
    "markdownlint-cli2", # better than `markdownlint`
    "mdbook", # better than `pandoc`
    "gitui", # better than `git-cli`
    "github:kunchenguid/treehouse", # better than `worktrunk`
    "tig", # better than `git log`

    # Shell Scripting Tools
    "shellcheck", "shfmt",    # Shell linter and formatter

    # Text Editors & IDE Tools
    "vim", "neovim",          # Text editors
    "vimPlugins.opencode-nvim",        # OpenCode Neovim plugin
    "vimPlugins.copilot-vim",         # GitHub Copilot Neovim plugin
    "vimPlugins.claudecode-nvim",      # Claude Code Neovim plugin
    "vimPlugins.tailwind-tools-nvim",  # Tailwind CSS Neovim plugin

    # Version Control & Git Tools
    "git",                    # Core version control
    "gh", "glab",             # GitHub and GitLab CLI tools
    "lazygit",                # Git TUI
    "git-extras", "git-lfs", "fzf-git-sh",          # Git extensions and tools

    # Document & Image Processing
    "poppler-utils", "chafa", "jp2a", "imagemagick", # PDF and image processing

    # Diff & Comparison Tools
    # Better diff
    "difftastic", "delta", "vimdiff",
    # Better nerge
    "mergiraf", "odiff",
    "quilt", "guilt",
