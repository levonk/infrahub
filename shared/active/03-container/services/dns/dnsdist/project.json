{
  "name": "localnet-dns-dnsdist",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/dns/dnsdist",
  "tags": ["service", "dns", "docker"],
  "implicitDependencies": ["localnet-base-debian"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/dns/dnsdist",
        "file": "services/dns/dnsdist/Dockerfile.dnsdist",
        "tags": ["localnet-dns-dnsdist:latest"],
        "push": false,
        "load": true
      }
    }
  }
}
