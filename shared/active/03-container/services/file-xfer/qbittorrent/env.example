# Environment Variables Template for qbittorrent (file-xfer)
# Copy to .env and adjust as needed.

# Core service
SERVICE_NAME=qbittorrent
NODE_ENV=production
TIMEZONE=UTC

# Web UI / API ports (env-based only)
QBIT_WEB_HOST_PORT=8701
QBIT_WEB_CONTAINER_PORT=8701
QBIT_TORRENT_HOST_PORT_TCP=6881
QBIT_TORRENT_HOST_PORT_UDP=6881
QBIT_TORRENT_CONTAINER_PORT=6881

# Health check
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# Optional logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/config/logs/qbittorrent.log
