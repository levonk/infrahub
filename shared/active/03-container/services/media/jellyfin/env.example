# Environment Variables Template
# Copy this to .env and customize for your environment

# Service Configuration
_SERVICE_NAME=jellyfin
_SERVICE_PORT=8096
_NODE_ENV=production
_PUID=1000
_PGID=1000
_TZ=America/Los_Angeles

# Health Check Configuration
_SERVICE_HEALTH_ENDPOINT=/health
_HEALTH_CHECK_INTERVAL=30s
_HEALTH_CHECK_TIMEOUT=10s
_HEALTH_CHECK_RETRIES=3

# Logging Configuration
_LOG_LEVEL=info
_LOG_FORMAT=json
_LOG_FILE=/app/logs/app.log

# Database Configuration (if applicable)
# _DATABASE_URL=postgresql://user:password@db:5432/
# _DATABASE_SSL_MODE=require
# _DATABASE_CONNECTION_POOL_SIZE=10

# Valkey / Redis Configuration (if applicable)
# _REDIS_URL=redis://redis:6379
# _REDIS_PASSWORD=
# _REDIS_DB=0

# External API Keys (use secure secret management in production)
# _API_KEY_1=your_api_key_here
# _API_KEY_2=your_api_key_here

# Monitoring Configuration
# _PROMETHEUS_METRICS_ENABLED=true
# _PROMETHEUS_METRICS_PORT=9090

# Security Configuration
# _SECRET_KEY_BASE=generate_a_strong_random_key_here
# _JWT_SECRET=generate_a_strong_random_key_here

# Feature Flags
# _ENABLE_DEBUG_MODE=false
# _ENABLE_CORS=true
# _ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Performance Configuration
# _MAX_WORKERS=4
# _REQUEST_TIMEOUT=30
# _RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# Email Configuration (if applicable)
# _SMTP_HOST=smtp.gmail.com
# _SMTP_PORT=587
# _SMTP_USER=your_email@gmail.com
# _SMTP_PASSWORD=your_app_password
# _FROM_EMAIL=noreply@yourdomain.com

# File Upload Configuration (if applicable)
# _UPLOAD_MAX_SIZE=10MB
# _UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf
# _UPLOAD_DESTINATION=/app/uploads

# Cache Configuration
# _CACHE_TTL=3600
# _CACHE_BACKEND=redis
# _CACHE_PREFIX=

# SSL/TLS Configuration
# _SSL_CERT_PATH=/path/to/cert.pem
# _SSL_KEY_PATH=/path/to/key.pem
# _SSL_CA_PATH=/path/to/ca.pem

