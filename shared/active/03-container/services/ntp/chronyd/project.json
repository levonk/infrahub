{
  "name": "localnet-ntp-chronyd",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/ntp/chronyd",
  "tags": ["service", "ntp", "docker"],
  "implicitDependencies": ["localnet-base-alpine"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/ntp/chronyd",
        "file": "services/ntp/chronyd/Dockerfile.chronyd",
        "tags": ["localnet-ntp-chronyd:latest"],
        "push": false,
        "load": true
      }
    }
  }
}
