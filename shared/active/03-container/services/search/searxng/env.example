# SearXNG Environment Variables
# Privacy-respecting metasearch engine configuration

# User/Group Configuration
SEARCH_SEARXNG_PUID=1000
SEARCH_SEARXNG_PGID=1000
SEARCH_SEARXNG_TZ=UTC

# Network Configuration
SEARCH_SEARXNG_HOST_IP=0.0.0.0
SEARCH_SEARXNG_HOST_PORT=8080
SEARCH_SEARXNG_CONTAINER_IP=0.0.0.0
SEARCH_SEARXNG_CONTAINER_PORT=8080

# NordVPN Proxy Configuration
# Routes all SearXNG traffic through NordVPN container
SEARCH_SEARXNG_HTTP_PROXY=http://nordvpn:1080
SEARCH_SEARXNG_HTTPS_PROXY=http://nordvpn:1080