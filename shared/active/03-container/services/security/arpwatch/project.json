{
  "name": "localnet-security-arpwatch",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "services/security/arpwatch",
  "tags": ["service", "security", "docker"],
  "implicitDependencies": ["localnet-base-alpine"],
  "targets": {
    "docker:build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": "services/security/arpwatch",
        "file": "services/security/arpwatch/Dockerfile.arpwatch",
        "tags": ["localnet-security-arpwatch:latest"],
        "push": false,
        "load": true
      }
    }
  }
}
