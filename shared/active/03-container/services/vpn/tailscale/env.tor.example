# Tailscale over Tor Environment Configuration
# Copy this file to .env and fill in the required values

# Tor Exit Node Configuration
TOR_EXIT_NODE_ENABLED=false  # Set to true to enable Tor as an exit node
TOR_NICKNAME=levonk-tor-exit
TOR_CONTACT_INFO=admin@levonk.com
TOR_EXIT_POLICY=reject *:*  # Conservative exit policy - customize as needed
TOR_BANDWIDTH_RATE=100 KB
TOR_BANDWIDTH_BURST=200 KB

# Network Configuration
TOR_NETWORK_SUBNET=172.30.0.0/16  # Tor network subnet (must not conflict with other networks)

# Tailscale Configuration
TS_AUTHKEY=your-tailscale-auth-key-here
TS_HOSTNAME=oci-vpn-server-tor

# General Configuration
TZ=UTC
